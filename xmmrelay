#!/bin/bash
# ====================================================
# 模块名称: 中转管理子系统 (Realm + Socat 双引擎 终极优化版)
# 更新内容: 智能架构识别、防重置TCP优化、后台常驻加固
# ====================================================

SCRIPT_DIR="/root/relay_scripts"
REALM_BIN="/usr/local/bin/realm"

GREEN='\033[0;32m'; YELLOW='\033[0;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; PLAIN='\033[0m'

install_deps() {
    echo -e "\n${CYAN}[*] 开始安装中转所需依赖...${PLAIN}"
    if command -v apt-get >/dev/null 2>&1; then
        apt-get update -y && apt-get install -y socat cron curl iproute2 net-tools nano wget >/dev/null 2>&1
    elif command -v apk >/dev/null 2>&1; then
        apk update && apk add socat bash cronie curl iproute2 net-tools nano wget >/dev/null 2>&1
        rc-update add cronie default && rc-service cronie start >/dev/null 2>&1
    elif command -v yum >/dev/null 2>&1; then
        yum install -y socat crontabs curl iproute net-tools nano wget >/dev/null 2>&1
    fi

    echo -e "${YELLOW}[*] 正在识别系统架构并拉取 Realm 核心...${PLAIN}"
    if [ ! -f "$REALM_BIN" ]; then
        # 自动识别 CPU 架构
        ARCH=$(uname -m)
        if [[ "$ARCH" == "aarch64" || "$ARCH" == "arm64" ]]; then
            REALM_ARCH="aarch64"
            echo -e "${GREEN}[+] 识别为 ARM64 架构，准备下载专属版本...${PLAIN}"
        elif [[ "$ARCH" == "x86_64" || "$ARCH" == "amd64" ]]; then
            REALM_ARCH="x86_64"
            echo -e "${GREEN}[+] 识别为 x86_64 架构，准备下载专属版本...${PLAIN}"
        else
            echo -e "${RED}[-] 未知或不支持的架构: $ARCH，请手动安装 Realm。${PLAIN}"
            sleep 2; return
        fi

        wget -qO /tmp/realm.tar.gz "https://github.com/zhboner/realm/releases/latest/download/realm-${REALM_ARCH}-unknown-linux-gnu.tar.gz"
        tar -xf /tmp/realm.tar.gz -C /usr/local/bin/ && chmod +x "$REALM_BIN"
        rm -f /tmp/realm.tar.gz
        echo -e "${GREEN}[+] Realm 核心部署成功！${PLAIN}"
    else
        echo -e "${GREEN}[+] Realm 已存在，无需重复安装。${PLAIN}"
    fi
    echo -e "\n按回车键返回..." && read -r
}

_execute_relay_setup() {
    echo -e "\n${YELLOW}[1/5] 选择引擎: 1=Realm(推荐), 2=Socat(纯粹转发)${PLAIN}"
    read -r engine_choice

    if [[ "$engine_choice" != "1" && "$engine_choice" != "2" ]]; then echo -e "${RED}选择无效。${PLAIN}"; sleep 1; return; fi

    echo -e "${YELLOW}[2/5] 监听端口:${PLAIN}" && read -r local_port
    if ss -tuln 2>/dev/null | grep -qE ":${local_port}\b"; then echo -e "${RED}端口 ${local_port} 已被占用！请先重置或更换端口。${PLAIN}"; sleep 1.5; return; fi

    echo -e "${YELLOW}[3/5] 落地机 IP 类型 (4=IPv4, 6=IPv6):${PLAIN}" && read -r ip_type
    echo -e "${YELLOW}[4/5] 落地机 IP 地址:${PLAIN}" && read -r remote_ip
    echo -e "${YELLOW}[5/5] 落地机 端口:${PLAIN}" && read -r remote_port

    # 净化输入的 IP 地址（防止用户误带中括号）
    remote_ip=$(echo "$remote_ip" | tr -d '[]')
    mkdir -p "$SCRIPT_DIR"

    # 智能检测本地是否为纯 IPv6 容器环境
    LOCAL_BIND="0.0.0.0:${local_port}"
    if [ ! -f /proc/net/if_inet6 ] || [ -z "$(ip -4 addr show 2>/dev/null | grep inet)" ]; then
        # 纯 IPv6 环境，监听绑定更改为 [::] 防止内核拒绝
        LOCAL_BIND="[::]:${local_port}"
    fi

    if [ "$engine_choice" == "1" ]; then
        REALM_IP=$([ "$ip_type" == "6" ] && echo "[${remote_ip}]" || echo "${remote_ip}")
        CONFIG_FILE="${SCRIPT_DIR}/realm_${local_port}.json"
        
        # 写入 JSON 配置（增加 fast_open 和 keepalive，专门对抗握手重置）
        cat << EOF > "$CONFIG_FILE"
{
  "log": { "level": "warn" },
  "network": { "no_tcp": false, "use_udp": true, "fast_open": true, "tcp_keepalive": 15 },
  "endpoints": [
    {
      "listen": "${LOCAL_BIND}",
      "remote": "${REALM_IP}:${remote_port}"
    }
  ]
}
EOF
        # 加固后台启动命令（使用绝对路径，确保输出重定向彻底脱离终端）
        nohup "$REALM_BIN" -c "$CONFIG_FILE" >/dev/null 2>&1 &
        CRON_CMD="nohup $REALM_BIN -c $CONFIG_FILE >/dev/null 2>&1 &"
        
        sleep 1
        if ps -ef | grep "$REALM_BIN" | grep -q "${local_port}"; then
            echo -e "${GREEN}[+] Realm 进程已稳稳扎根后台！${PLAIN}"
        else
            echo -e "${RED}[-] Realm 进程启动异常，请检查配置或环境限制。${PLAIN}"
        fi
    else
        SCRIPT_FILE="${SCRIPT_DIR}/relay_${local_port}.sh"
        if [ "$ip_type" == "4" ]; then TARGET_TCP="TCP4:${remote_ip}:${remote_port}"; TARGET_UDP="UDP4:${remote_ip}:${remote_port}"; else TARGET_TCP="TCP6:[${remote_ip}]:${remote_port}"; TARGET_UDP="UDP6:[${remote_ip}]:${remote_port}"; fi
        
        # 针对纯 IPv6 容器的 Socat 监听优化
        if [[ "$LOCAL_BIND" == *"[::]"* ]]; then
            SOCAT_LISTEN_TCP="TCP6-LISTEN:${local_port},reuseaddr,fork"
            SOCAT_LISTEN_UDP="UDP6-LISTEN:${local_port},reuseaddr,fork"
        else
            SOCAT_LISTEN_TCP="TCP4-LISTEN:${local_port},reuseaddr,fork"
            SOCAT_LISTEN_UDP="UDP4-LISTEN:${local_port},reuseaddr,fork"
        fi

        cat << EOF > "$SCRIPT_FILE"
#!/bin/bash
ulimit -n 65535 2>/dev/null
nohup socat ${SOCAT_LISTEN_TCP},nodelay,keepalive ${TARGET_TCP} >/dev/null 2>&1 &
nohup socat ${SOCAT_LISTEN_UDP} ${TARGET_UDP} >/dev/null 2>&1 &
EOF
        chmod +x "$SCRIPT_FILE" && bash "$SCRIPT_FILE"
        CRON_CMD="bash $SCRIPT_FILE"
        sleep 1
    fi

    # 写入开机自启
    (crontab -l 2>/dev/null | grep -v "$CRON_CMD"; echo "@reboot ${CRON_CMD}") | crontab -
    echo -e "${GREEN}[+] 转发配置彻底完成并已写入开机自启！端口: ${local_port}${PLAIN}"
}

add_relay_append() {
    _execute_relay_setup
    echo -e "\n按回车键返回..." && read -r
}

reset_and_setup_relay() {
    echo -e "\n${RED}⚠️ 警告：将清除所有旧转发规则！确定？(y/n)${PLAIN}"
    read -r confirm; [[ "$confirm" != "y" && "$confirm" != "Y" ]] && return
    
    for f in "$SCRIPT_DIR"/*; do
        if [[ "$f" == *"relay_"*".sh" ]]; then port=$(basename "$f" | sed -E 's/(relay_|\.sh)//g'); ps -ef | grep "socat" | grep "LISTEN:${port}," | awk '{print $2}' | xargs kill -9 2>/dev/null; fi
        if [[ "$f" == *"realm_"*".json" ]]; then port=$(basename "$f" | sed -E 's/(realm_|\.json)//g'); ps -ef | grep "realm" | grep "${port}" | awk '{print $2}' | xargs kill -9 2>/dev/null; fi
    done
    rm -f "$SCRIPT_DIR"/relay_*.sh "$SCRIPT_DIR"/realm_*.json
    crontab -l 2>/dev/null | grep -vE "(relay_|realm_)" | crontab - 2>/dev/null
    
    echo -e "${GREEN}[+] 端口已释放，垃圾清理完毕，开始全新配置。${PLAIN}"
    _execute_relay_setup
    echo -e "\n按回车键返回..." && read -r
}

edit_relay_by_nano() {
    local files=($(find "$SCRIPT_DIR" -maxdepth 1 -type f \( -name "relay_*.sh" -o -name "realm_*.json" \) 2>/dev/null))
    [ ${#files[@]} -eq 0 ] && { echo -e "${RED}无配置记录！${PLAIN}"; sleep 1; return; }

    echo -e "${GREEN}检测到以下运行规则：${PLAIN}"
    for i in "${!files[@]}"; do
        port=$(basename "${files[$i]}" | sed -E 's/(relay_|realm_|\.sh|\.json)//g')
        echo "  [$((i+1))] 端口：${port}"
    done
    read -p "输入序号编辑: " idx
    [ -z "${files[$((idx-1))]}" ] && return
    
    selected_file="${files[$((idx-1))]}"
    selected_port=$(basename "$selected_file" | sed -E 's/(relay_|realm_|\.sh|\.json)//g')
    nano "$selected_file"

    if [[ "$selected_file" == *.sh ]]; then
        ps -ef | grep "socat" | grep "LISTEN:${selected_port}," | awk '{print $2}' | xargs kill -9 2>/dev/null; bash "$selected_file"
    else
        ps -ef | grep "realm" | grep "${selected_port}" | awk '{print $2}' | xargs kill -9 2>/dev/null; nohup "$REALM_BIN" -c "$selected_file" >/dev/null 2>&1 &
    fi
    echo -e "${GREEN}[+] 热重启生效！${PLAIN}"
    echo -e "\n按回车键返回..." && read -r
}

if [ -n "$1" ]; then
    "$1"
fi
