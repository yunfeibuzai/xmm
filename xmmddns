#!/bin/bash
# ====================================================
# 模块名称: Cloudflare DDNS 子系统 (优化版)
# ====================================================

SCRIPT_DIR="/root/relay_scripts"
DDNS_LOG="/var/log/xmm_ddns.log"

GREEN='\033[0;32m'; YELLOW='\033[0;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; PLAIN='\033[0m'

setup_ddns() {
    echo -e "\n${CYAN}--- 配置 Cloudflare DDNS ---${PLAIN}"
    
    # 检查并安装核心依赖 jq
    if ! command -v jq &> /dev/null; then
        echo -e "${YELLOW}[*] 未检测到 jq，正在自动安装以保障解析稳定性...${PLAIN}"
        if [ -x "$(command -v apt-get)" ]; then apt-get update >/dev/null 2>&1 && apt-get install -y jq >/dev/null 2>&1
        elif [ -x "$(command -v yum)" ]; then yum install -y epel-release >/dev/null 2>&1 && yum install -y jq >/dev/null 2>&1
        else echo -e "${RED}[-] 自动安装 jq 失败，请手动安装后重试。${PLAIN}"; return 1; fi
    fi

    read -p "[1/4] CF 解析域名 (例: relay.xmm.com): " ddns_domain
    read -p "[2/4] 解析类型 (4=IPv4, 6=IPv6): " ddns_type
    read -p "[3/4] CF API Token: " cf_token
    read -p "[4/4] CF Zone ID: " cf_zone_id

    RECORD_TYPE=$([ "$ddns_type" == "4" ] && echo "A" || echo "AAAA")
    
    # 确保目录存在
    mkdir -p "$SCRIPT_DIR"
    DDNS_SCRIPT="${SCRIPT_DIR}/cf_ddns.sh"

    # 生成内部 DDNS 脚本
    cat << 'EOF' > "$DDNS_SCRIPT"
#!/bin/bash
DOMAIN="MY_DOMAIN"
IP_TYPE="MY_IP_TYPE"
CF_TOKEN="MY_CF_TOKEN"
ZONE_ID="MY_ZONE_ID"
RECORD_TYPE="MY_RECORD_TYPE"
LOG_FILE="MY_LOG_FILE"

write_log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$LOG_FILE"
    tail -n 30 "$LOG_FILE" > "${LOG_FILE}.tmp" && mv "${LOG_FILE}.tmp" "$LOG_FILE"
}

# 1. 获取本地公网 IP
CURRENT_IP=$([ "$IP_TYPE" == "4" ] && curl -s4 https://api.ipify.org || curl -s6 https://api64.ipify.org)
[ -z "$CURRENT_IP" ] && { write_log "❌ 获取本地 IP 失败"; exit 1; }

# 2. 从 Cloudflare 获取当前解析记录
RECORD_INFO=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones/${ZONE_ID}/dns_records?type=${RECORD_TYPE}&name=${DOMAIN}" \
    -H "Authorization: Bearer ${CF_TOKEN}" \
    -H "Content-Type: application/json")

# 检查 API 是否请求成功
API_SUCCESS=$(echo "$RECORD_INFO" | jq -r '.success // false')
if [ "$API_SUCCESS" != "true" ]; then
    write_log "❌ 请求 CF API 失败，请检查 Token 或 Zone ID"
    exit 1
fi

# 3. 统计记录数量，防止一个域名对应多个 IP 产生混乱
RECORD_COUNT=$(echo "$RECORD_INFO" | jq -r '.result | length')

if [ "$RECORD_COUNT" -gt 1 ]; then
    write_log "⚠️ 警告：发现域名存在多个同类型记录！为防止混乱，请前往 CF 后台手动清理至 1 个。"
    exit 1
elif [ "$RECORD_COUNT" -eq 1 ]; then
    # 存在唯一记录，提取 ID 和 旧 IP，判断是否需要更新
    RECORD_ID=$(echo "$RECORD_INFO" | jq -r '.result[0].id')
    OLD_IP=$(echo "$RECORD_INFO" | jq -r '.result[0].content')

    if [ "$CURRENT_IP" != "$OLD_IP" ]; then
        RESULT=$(curl -s -X PUT "https://api.cloudflare.com/client/v4/zones/${ZONE_ID}/dns_records/${RECORD_ID}" \
            -H "Authorization: Bearer ${CF_TOKEN}" \
            -H "Content-Type: application/json" \
            --data "{\"type\":\"${RECORD_TYPE}\",\"name\":\"${DOMAIN}\",\"content\":\"${CURRENT_IP}\",\"ttl\":60,\"proxied\":false}")
        echo "$RESULT" | jq -e '.success' >/dev/null && write_log "✅ 更新 IP -> $CURRENT_IP" || write_log "❌ 更新失败"
    else
        write_log "ℹ️ IP 未改变 ($CURRENT_IP)"
    fi
else
    # 不存在记录，执行新建动作
    RESULT=$(curl -s -X POST "https://api.cloudflare.com/client/v4/zones/${ZONE_ID}/dns_records" \
        -H "Authorization: Bearer ${CF_TOKEN}" \
        -H "Content-Type: application/json" \
        --data "{\"type\":\"${RECORD_TYPE}\",\"name\":\"${DOMAIN}\",\"content\":\"${CURRENT_IP}\",\"ttl\":60,\"proxied\":false}")
    echo "$RESULT" | jq -e '.success' >/dev/null && write_log "✅ 新建解析 -> $CURRENT_IP" || write_log "❌ 新建失败"
fi
EOF

    # 替换变量占位符
    sed -i "s|MY_DOMAIN|${ddns_domain}|g; s|MY_IP_TYPE|${ddns_type}|g; s|MY_CF_TOKEN|${cf_token}|g; s|MY_ZONE_ID|${cf_zone_id}|g; s|MY_RECORD_TYPE|${RECORD_TYPE}|g; s|MY_LOG_FILE|${DDNS_LOG}|g" "$DDNS_SCRIPT"
    chmod +x "$DDNS_SCRIPT"
    
    echo -e "${YELLOW}[*] 尝试首次同步...${PLAIN}"
    bash "$DDNS_SCRIPT"
    
    # 检测运行结果
    if tail -n 1 "$DDNS_LOG" | grep -qE "✅|ℹ️"; then
        echo -e "${GREEN}[+] DDNS 配置成功！已加入定时任务。${PLAIN}"
        (crontab -l 2>/dev/null | grep -v "$DDNS_SCRIPT"; echo "*/5 * * * * bash $DDNS_SCRIPT >/dev/null 2>&1") | crontab -
    else
        echo -e "${RED}[-] 测试失败，请检查参数配置或日志。${PLAIN}"
    fi
    echo -e "\n按回车键返回..." && read -r
}

view_logs() {
    echo -e "\n${CYAN}=== DDNS 日志 ===${PLAIN}"
    [ -f "$DDNS_LOG" ] && cat "$DDNS_LOG" || echo -e "${RED}暂无记录。${PLAIN}"
    echo -e "${CYAN}=================${PLAIN}"
    echo -e "\n按回车键返回..." && read -r
}

# 接收主控传入的指令并执行对应的函数
if [ -n "$1" ]; then
    "$1"
fi
