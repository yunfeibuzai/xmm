#!/bin/bash

# 定义颜色以便在终端显示更清晰
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
PLAIN='\033[0m'

# ==========================================
# 功能 1：安装必要依赖
# ==========================================
install_deps() {
    echo -e "\n${YELLOW}开始检测并安装所需依赖 (socat / cron)...${PLAIN}"
    if command -v apt-get >/dev/null 2>&1; then
        apt-get update -y >/dev/null 2>&1
        apt-get install -y socat cron >/dev/null 2>&1
        echo -e "${GREEN}✅ 依赖安装完成 (Debian/Ubuntu 环境)${PLAIN}"
    elif command -v apk >/dev/null 2>&1; then
        # Alpine 环境下同时补全 bash 和 cronie
        apk update >/dev/null 2>&1
        apk add socat bash cronie >/dev/null 2>&1
        rc-update add cronie default >/dev/null 2>&1 && rc-service cronie start >/dev/null 2>&1
        echo -e "${GREEN}✅ 依赖安装完成 (Alpine 环境)${PLAIN}"
    elif command -v yum >/dev/null 2>&1; then
        yum install -y socat crontabs >/dev/null 2>&1
        echo -e "${GREEN}✅ 依赖安装完成 (CentOS/RHEL 环境)${PLAIN}"
    else
        echo -e "${RED}❌ 未找到支持的包管理器，请手动安装 socat。${PLAIN}"
    fi
    
    echo -e "\n请按回车键返回主菜单..."
    read -r
}

# ==========================================
# 功能 2：一键中转对接脚本
# ==========================================
setup_relay() {
    echo -e "\n${YELLOW}--- 开始配置中转转发 ---${PLAIN}"
    
    # 检查 socat 是否安装
    if ! command -v socat >/dev/null 2>&1; then
        echo -e "${RED}警告：未检测到 socat，请先在主菜单选择 1 安装依赖！${PLAIN}"
        echo -e "\n请按回车键返回主菜单..."
        read -r
        return
    fi

    echo -e "\n[1/4] 请输入监听端口 (当前中转服务器开放、用于连接的端口):"
    read -r local_port

    echo -e "\n[2/4] 请输入落地服务器的转发类型 (输入 4 代表 IPv4, 输入 6 代表 IPv6):"
    read -r ip_type

    echo -e "\n[3/4] 请输入落地服务器的 IP 地址 (输入 V6 时可带括号也可不带):"
    read -r remote_ip

    echo -e "\n[4/4] 请输入落地服务器的端口 (实际的服务端口):"
    read -r remote_port

    # 处理 IPv6 格式并生成命令
    remote_ip=$(echo "$remote_ip" | tr -d '[]')

    if [ "$ip_type" == "4" ]; then
        TARGET_TCP="TCP4:${remote_ip}:${remote_port}"
        TARGET_UDP="UDP4:${remote_ip}:${remote_port}"
    elif [ "$ip_type" == "6" ]; then
        TARGET_TCP="TCP6:[${remote_ip}]:${remote_port}"
        TARGET_UDP="UDP6:[${remote_ip}]:${remote_port}"
    else
        echo -e "${RED}❌ 输入错误：转发类型只能输入 4 或 6。${PLAIN}"
        echo -e "\n请按回车键返回主菜单..."
        read -r
        return
    fi

    # 生成独立守护脚本
    SCRIPT_DIR="/root/relay_scripts"
    mkdir -p "$SCRIPT_DIR"
    SCRIPT_FILE="${SCRIPT_DIR}/relay_${local_port}.sh"

    cat << EOF > "$SCRIPT_FILE"
#!/bin/bash
# 启动 TCP 转发
nohup socat TCP-LISTEN:${local_port},reuseaddr,fork ${TARGET_TCP} > /dev/null 2>&1 &

# 启动 UDP 转发
nohup socat UDP-LISTEN:${local_port},reuseaddr,fork ${TARGET_UDP} > /dev/null 2>&1 &
EOF

    chmod +x "$SCRIPT_FILE"

    # 执行并利用 crontab 设置开机自启
    bash "$SCRIPT_FILE"

    if command -v crontab >/dev/null 2>&1; then
        if ! crontab -l 2>/dev/null | grep -q "$SCRIPT_FILE"; then
            (crontab -l 2>/dev/null; echo "@reboot bash $SCRIPT_FILE") | crontab -
        fi
    fi

    echo "======================================================"
    echo -e "${GREEN}✅ 转发配置完成并已在后台运行！${PLAIN}"
    echo "中转监听端口: ${local_port} (支持 TCP/UDP)"
    echo "落地目标地址: ${remote_ip}"
    echo "落地服务端口: ${remote_port}"
    echo "自启状态: 已加入 crontab (@reboot)"
    echo "======================================================"
    
    echo -e "\n请按回车键返回主菜单..."
    read -r
}

# ==========================================
# 主菜单循环
# ==========================================
while true; do
    clear
    echo "======================================================"
    echo -e "        ${GREEN}极简中转转发管理面板 (TCP+UDP)${PLAIN}"
    echo -e "        ${YELLOW}兼容 Debian / Ubuntu / Alpine / CentOS${PLAIN}"
    echo "======================================================"
    echo "  1. 安装必要依赖 (首次使用请先安装)"
    echo "  2. 一键配置中转对接"
    echo "  0. 退出脚本"
    echo "======================================================"
    echo -n "请输入选项 [0-2]: "
    read -r choice

    case "$choice" in
        1)
            install_deps
            ;;
        2)
            setup_relay
            ;;
        0)
            echo -e "${GREEN}感谢使用，已退出！${PLAIN}"
            exit 0
            ;;
        *)
            echo -e "${RED}输入错误，请输入 0, 1 或 2${PLAIN}"
            sleep 2
            ;;
    esac
done
