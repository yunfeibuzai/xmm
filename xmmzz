#!/bin/bash
# ====================================================
# 项目名称: 极简网络中转管理面板 (主控模块)
# 项目版本: v2.0.0 (模块化重构)
# ====================================================

GITHUB_REPO_URL="https://raw.githubusercontent.com/yunfeibuzai/xmm/main"
SCRIPT_DIR="/root/relay_scripts"

# 更新为对应的模块文件名
RELAY_MODULE="${SCRIPT_DIR}/xmmrelay"
DDNS_MODULE="${SCRIPT_DIR}/xmmddns"

GREEN='\033[0;32m'; YELLOW='\033[0;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; PLAIN='\033[0m'

# 0. 环境与模块初始化
init_env() {
    ulimit -n 65535 2>/dev/null
    mkdir -p "$SCRIPT_DIR"

    # 面板命令注入
    if [ ! -f "/usr/local/bin/xmm" ]; then
        cp "$0" /usr/local/bin/xmm 2>/dev/null || cp "$0" /usr/bin/xmm
        chmod +x /usr/local/bin/xmm 2>/dev/null || chmod +x /usr/bin/xmm
        echo -e "${GREEN}[+] 快捷控制台面板已注入！输入快捷键：${YELLOW}xmm${GREEN} 即可唤醒。${PLAIN}"
        sleep 1.5
    fi

    # 动态拉取子模块 (如果不存在，则从你的 GitHub 仓库拉取)
    if [ ! -f "$RELAY_MODULE" ]; then
        curl -sSfL "${GITHUB_REPO_URL}/xmmrelay" -o "$RELAY_MODULE" && chmod +x "$RELAY_MODULE"
    fi
    if [ ! -f "$DDNS_MODULE" ]; then
        curl -sSfL "${GITHUB_REPO_URL}/xmmddns" -o "$DDNS_MODULE" && chmod +x "$DDNS_MODULE"
    fi
}

# 模块调用包装器
call_relay() {
    [ -f "$RELAY_MODULE" ] && bash "$RELAY_MODULE" "$1" || echo -e "${RED}[-] 中转模块缺失，请检查网络或执行更新！${PLAIN}"
}

call_ddns() {
    [ -f "$DDNS_MODULE" ] && bash "$DDNS_MODULE" "$1" || echo -e "${RED}[-] DDNS模块缺失，请检查网络或执行更新！${PLAIN}"
}

# 一键更新功能 (适配你的新文件名)
update_all_scripts() {
    echo -e "\n${CYAN}[*] 正在从 GitHub 同步所有模块代码...${PLAIN}"
    # 假设你的主控脚本在仓库里叫 xmmzz，如果叫别的请自行修改下面这行
    curl -sSfL "${GITHUB_REPO_URL}/xmmzz" -o /tmp/xmmzz.tmp
    curl -sSfL "${GITHUB_REPO_URL}/xmmrelay" -o /tmp/xmmrelay.tmp
    curl -sSfL "${GITHUB_REPO_URL}/xmmddns" -o /tmp/xmmddns.tmp

    # 效验下载是否成功
    if grep -q "#!/bin/bash" /tmp/xmmzz.tmp; then
        mv /tmp/xmmzz.tmp /usr/local/bin/xmm && chmod +x /usr/local/bin/xmm
        mv /tmp/xmmrelay.tmp "$RELAY_MODULE" && chmod +x "$RELAY_MODULE"
        mv /tmp/xmmddns.tmp "$DDNS_MODULE" && chmod +x "$DDNS_MODULE"
        echo -e "${GREEN}[+] 所有模块升级成功！正在重新载入...${PLAIN}"
        sleep 1; exec bash /usr/local/bin/xmm
    else
        echo -e "${RED}[-] 下载失败，可能遭遇网络波动，请稍后再试。${PLAIN}"
        rm -f /tmp/xmmzz.tmp /tmp/xmmrelay.tmp /tmp/xmmddns.tmp
    fi
    echo -e "\n按回车键返回..." && read -r
}

# ==========================================
# 主流程启动
# ==========================================
init_env

while true; do
    clear
    echo "======================================================"
    echo -e "    ${GREEN}极简网络中转管理面板${PLAIN} ${CYAN}(模块化核心) v2.0.0${PLAIN}"
    echo "======================================================"
    echo -e "  ${GREEN}1.${PLAIN} 安装中转依赖 (Realm/Socat)"
    echo -e "  ${GREEN}2.${PLAIN} 追加新中转配置"
    echo -e "  ${GREEN}3.${PLAIN} 重置并全新配置 (清理旧规则)"
    echo -e "  ${GREEN}4.${PLAIN} 手动修改中转配置 (热重启)"
    echo "------------------------------------------------------"
    echo -e "  ${GREEN}5.${PLAIN} 配置 Cloudflare DDNS 同步"
    echo -e "  ${GREEN}6.${PLAIN} 查看 DDNS 运行日志"
    echo "------------------------------------------------------"
    echo -e "  ${GREEN}7.${PLAIN} 一键更新面板与所有模块"
    echo -e "  ${GREEN}0.${PLAIN} 退出"
    echo "======================================================"
    read -p "请输入选项 [0-7]: " choice

    case "$choice" in
        1) call_relay install_deps ;;
        2) call_relay add_relay_append ;;
        3) call_relay reset_and_setup_relay ;;
        4) call_relay edit_relay_by_nano ;;
        5) call_ddns setup_ddns ;;
        6) call_ddns view_logs ;;
        7) update_all_scripts ;;
        0) echo -e "${GREEN}[+] 退出面板！${PLAIN}"; exit 0 ;;
        *) echo -e "${RED}[-] 输入错误。${PLAIN}"; sleep 1 ;;
    esac
done
