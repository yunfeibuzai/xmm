#!/bin/bash
# 模块：追加节点配置
red='\033[31m'; green='\033[32m'; yellow='\033[33m'; magenta='\033[35m'; cyan='\033[36m'; plain='\033[0m'
config_file="/etc/V2bX/config.json"

echo -e "\n${yellow}========== 进入配置追加向导模式 ==========${plain}"
if [[ ! -f "$config_file" ]]; then echo -e "${red}[错误] 未找到配置文件${plain}"; exit 1; fi

api_host=$(jq -r '.Nodes[0].ApiHost' "$config_file" 2>/dev/null)
api_key=$(jq -r '.Nodes[0].ApiKey' "$config_file" 2>/dev/null)
[[ -z "$api_host" || "$api_host" == "null" ]] && api_host="https://example.com"

echo -e "${green}[读取成功] 已对接机场: ${cyan}${api_host}${plain}"
added_count=0

while true; do
    ((added_count++))
    read -rp "请输入节点 Node ID: " node_id
    read -rp "请输入传输协议(vless/vmess/trojan): " node_type
    read -rp "请输入监听端口 (默认 20026): " input_port
    node_port=${input_port:-"20026"}

    current_node='{
"Core": "xray", "ApiHost": "'"${api_host}"'", "ApiKey": "'"${api_key}"'", "NodeID": '"${node_id}"', "NodeType": "'"${node_type}"'",
"Timeout": 30, "ListenIP": "::", "SendIP": "0.0.0.0", "Port": '"${node_port}"', "DeviceOnlineMinTraffic": 200, "MinReportTraffic": 0,
"TCPFastOpen": true, "SniffEnabled": true, "CertConfig": { "CertMode": "none" }
}'

    jq --argjson newNode "$current_node" '.Nodes += [$newNode]' "$config_file" > "${config_file}.tmp" && mv -f "${config_file}.tmp" "$config_file"
    echo -e "${green}[成功] 节点 ID: ${node_id} 已追加。${plain}"
    
    read -rp "是否继续添加？(y/n) " continue_yn
    [[ "$continue_yn" != "y" && "$continue_yn" != "Y" ]] && break
done
echo -e "${green}追加完毕！${plain}"
