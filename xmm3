#!/bin/bash

# 麦卖云 V2bX 节点独立配置向导引擎 (增量追加 + CF隧道全能版)
sh_ver="2.0.0"
red='\033[31m'; green='\033[32m'; yellow='\033[33m'
magenta='\033[35m'; cyan='\033[36m'; plain='\033[0m'

config_file="/etc/V2bX/config.json"

# ==========================================
# 模块 1：原有配置增量追加逻辑
# ==========================================
append_nodes() {
    echo -e "\n${yellow}========== 进入配置追加向导模式 ==========${plain}"

    # 安全检查
    if [[ ! -f "$config_file" ]]; then
        echo -e "${red}[错误] 未检测到基础配置文件 ${config_file}${plain}"
        echo -e "${yellow}请先返回主菜单使用选项 11 创建初始节点配置矩阵！${plain}"
        exit 1
    fi

    if ! command -v jq &>/dev/null; then
        echo -e "${red}[错误] 本脚本必须依赖 jq 才能精准追加配置，请确保基础环境完整。${plain}"
        exit 1
    fi

    # 自动读取已有凭证
    api_host=$(jq -r '.Nodes[0].ApiHost' "$config_file" 2>/dev/null)
    api_key=$(jq -r '.Nodes[0].ApiKey' "$config_file" 2>/dev/null)

    if [[ -z "$api_host" || "$api_host" == "null" ]]; then
        api_host="https://example.com"
    fi

    echo -e "${green}[读取成功] 自动复用当前已对接机场: ${cyan}${api_host}${plain}"

    has_xray=false
    has_sing=false
    has_hysteria2=false
    added_count=0

    # 循环向内存追加节点
    while true; do
        ((added_count++))
        echo -e "\n${magenta}--------------------------------------------${plain}"
        echo -e "${magenta}🌟 开始配置准备追加的第 ${added_count} 个新节点：${plain}"
        echo -e "${magenta}--------------------------------------------${plain}"

        core_num="" core_type="" node_id="" protocol_num="" node_type=""
        reality_yn="n" tls_yn="n" cert_mode_num="" cert_mode="none" cert_domain="" cf_token="" node_port=""

        echo -e "请 选 择 节 点 核 心 类 型 ："
        echo -e "1. xray"
        echo -e "2. singbox"
        echo -e "3. hysteria2"
        while [[ ! "$core_num" =~ ^[1-3]$ ]]; do
            read -rp "请 输 入 ： " core_num
        done
        case "$core_num" in 
            1) core_type="xray"; has_xray=true ;; 
            2) core_type="sing"; has_sing=true ;; 
            3) core_type="hysteria2"; has_hysteria2=true ;; 
        esac

        while [[ -z "$node_id" ]]; do
            read -rp "请 输 入 节 点 Node ID： " node_id
        done

        echo -e "请 选 择 节 点 传 输 协 议 ："
        echo -e "1. Shadowsocks"
        echo -e "2. Vless"
        echo -e "3. Vmess"
        echo -e "4. Hysteria"
        echo -e "5. Hysteria2"
        echo -e "6. Trojan"
        echo -e "7. Tuic"
        echo -e "8. AnyTLS"
        while [[ ! "$protocol_num" =~ ^[1-8]$ ]]; do
            read -rp "请 输 入 ： " protocol_num
        done

        case "$protocol_num" in
            1) node_type="shadowsocks" ;; 2) node_type="vless" ;; 3) node_type="vmess" ;; 4) node_type="hysteria" ;;
            5) node_type="hysteria2" ;; 6) node_type="trojan" ;; 7) node_type="tuic" ;; 8) node_type="anytls" ;;
        esac

        run_tls_flow=false
        if [[ "$protocol_num" == "1" || "$protocol_num" == "3" || "$protocol_num" == "6" || "$protocol_num" == "8" ]]; then
            read -rp "请 选 择 是 否 进 行 TLS配 置 ？ (y/n)" tls_yn
            [[ "$tls_yn" == "y" || "$tls_yn" == "Y" ]] && run_tls_flow=true
        elif [[ "$protocol_num" == "2" ]]; then
            read -rp "请 选 择 是 否 为 reality节 点 ？ (y/n)" reality_yn
            if [[ "$reality_yn" == "y" || "$reality_yn" == "Y" ]]; then
                cert_mode="none"
            else
                read -rp "请 选 择 是 否 进 行 TLS配 置 ？ (y/n)" tls_yn
                [[ "$tls_yn" == "y" || "$tls_yn" == "Y" ]] && run_tls_flow=true
            fi
        elif [[ "$protocol_num" == "4" || "$protocol_num" == "5" || "$protocol_num" == "7" ]]; then
            run_tls_flow=true
        fi

        if [ "$run_tls_flow" = true ]; then
            echo -e "请 选 择 证 书 申 请 模 式 ："
            echo -e "1. http模 式 自 动 申 请 ， 节 点 域 名 已 正 确 解 析"
            echo -e "2. dns模 式 自 动 申 请 ， 需 填 入 正 确 域 名 服 务商 API参 数"
            echo -e "3. self模 式 ， 自 签 证 书 或 提 供 已 有 证 书 文 件"
            while [[ ! "$cert_mode_num" =~ ^[1-3]$ ]]; do
                read -rp "请 输 入 ： " cert_mode_num
            done

            if [[ "$cert_mode_num" == "1" || "$cert_mode_num" == "2" ]]; then
                while [[ -z "$cert_domain" ]]; do
                    read -rp "请输入证书申请域名 (如 domain.com): " cert_domain
                done
                if [[ "$cert_mode_num" == "1" ]]; then
                    cert_mode="http"
                else
                    cert_mode="dns"
                    while [[ -z "$cf_token" ]]; do
                        read -rp "CLOUDFLARE_DNS_API_TOKEN: 填入 CF_Token: " cf_token
                    done
                fi
            elif [[ "$cert_mode_num" == "3" ]]; then
                cert_mode="self"
            fi
        fi

        cert_block=""
        if [[ "$cert_mode" == "dns" ]]; then
            cert_block='{ "CertMode": "dns", "RejectUnknownSni": false, "CertDomain": "'"${cert_domain}"'", "CertFile": "/etc/V2bX/server.crt.cer", "KeyFile": "/etc/V2bX/cert.key", "Email": "v2bx@github.com", "Provider": "cloudflare", "DNSEnv": { "CLOUDFLARE_DNS_API_TOKEN": "'"${cf_token}"'" } }'
        elif [[ "$cert_mode" == "http" ]]; then
            cert_block='{ "CertMode": "http", "RejectUnknownSni": false, "CertDomain": "'"${cert_domain}"'", "CertFile": "/etc/V2bX/server.crt.cer", "KeyFile": "/etc/V2bX/cert.key", "Email": "v2bx@github.com" }'
        elif [[ "$cert_mode" == "self" ]]; then
            cert_block='{ "CertMode": "self", "RejectUnknownSni": false, "CertDomain": "cf.babymonster.cc.cd", "CertFile": "/etc/V2bX/server.crt.cer", "KeyFile": "/etc/V2bX/cert.key", "Email": "v2bx@github.com" }'
        else
            cert_block='{ "CertMode": "none" }'
        fi

        read -rp "请 输 入 该 节 点 监 听 端 口 (直接回车默认 20026)： " input_port
        node_port=${input_port:-"20026"}

        current_node='{
"Core": "'"${core_type}"'", "ApiHost": "'"${api_host}"'", "ApiKey": "'"${api_key}"'", "NodeID": '"${node_id}"', "NodeType": "'"${node_type}"'",
"Timeout": 30, "ListenIP": "::", "SendIP": "0.0.0.0", "Port": '"${node_port}"', "DeviceOnlineMinTraffic": 200, "MinReportTraffic": 0,
"TCPFastOpen": true, "SniffEnabled": true, "CertConfig": '"${cert_block}"'
}'

        cp -f "$config_file" "${config_file}.bak"
        if jq --argjson newNode "$current_node" '.Nodes += [$newNode]' "$config_file" > "${config_file}.tmp" 2>/dev/null; then
            mv -f "${config_file}.tmp" "$config_file"
            echo -e "${green}[成功] 节点 ID: ${node_id} 已增量写入配置缓冲区。${plain}"
        else
            echo -e "${red}[错误] 节点合并失败，已恢复原始备份。${plain}"
            rm -f "${config_file}.tmp"
        fi

        if [ "$has_xray" = true ] && [ "$(jq '.Cores | map(select(.Type == "xray")) | length' "$config_file" 2>/dev/null)" -eq 0 ]; then
            jq '.Cores += [{"Type": "xray", "Log": { "Level": "error", "Timestamp": true }, "NTP": { "Enable": false, "Server": "time.apple.com", "ServerPort": 0 }, "OriginalPath": "/etc/V2bX/sing_origin.json"}]' "$config_file" > "${config_file}.tmp" && mv -f "${config_file}.tmp" "$config_file"
        fi
        if [ "$has_sing" = true ] && [ "$(jq '.Cores | map(select(.Type == "sing")) | length' "$config_file" 2>/dev/null)" -eq 0 ]; then
            jq '.Cores += [{"Type": "sing", "Log": { "Level": "error", "Timestamp": true }, "NTP": { "Enable": false, "Server": "time.apple.com", "ServerPort": 0 }, "OriginalPath": "/etc/V2bX/sing_origin.json"}]' "$config_file" > "${config_file}.tmp" && mv -f "${config_file}.tmp" "$config_file"
        fi
        if [ "$has_hysteria2" = true ] && [ "$(jq '.Cores | map(select(.Type == "hysteria2")) | length' "$config_file" 2>/dev/null)" -eq 0 ]; then
            jq '.Cores += [{"Type": "hysteria2", "Log": { "Level": "error", "Timestamp": true }, "NTP": { "Enable": false, "Server": "time.apple.com", "ServerPort": 0 }, "OriginalPath": "/etc/V2bX/sing_origin.json"}]' "$config_file" > "${config_file}.tmp" && mv -f "${config_file}.tmp" "$config_file"
        fi

        echo -e ""
        read -rp "是否需要继续添加下一个节点？(y/n) " continue_yn
        if [[ "$continue_yn" != "y" && "$continue_yn" != "Y" ]]; then
            break
        fi
    done

    jq . "$config_file" > "${config_file}.tmp" && mv -f "${config_file}.tmp" "$config_file"
    rm -f "${config_file}.bak"

    echo -e "${green}[大功告成] 本次共成功追加了 ${added_count} 个节点！现有配置已重新对齐美化输出。${plain}"
}


# ==========================================
# 模块 2：Cloudflare Argo Tunnel (CF隧道) 部署向导
# ==========================================
setup_cf_tunnel() {
    echo -e "\n${cyan}====== 🛠️ Cloudflare Argo Tunnel (CF隧道) 部署向导 ======${plain}"
    
    # 1. 检测并安装必备组件 cloudflared
    if ! command -v cloudflared &> /dev/null; then
        echo -e "${yellow}未检测到 cloudflared 核心，正在从官方拉取最新版...${plain}"
        local arch
        case $(uname -m) in
            x86_64 | amd64) arch="amd64" ;;
            aarch64 | arm64) arch="arm64" ;;
            *) echo -e "${red}不支持的系统架构！${plain}"; exit 1 ;;
        esac
        
        local cf_url="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${arch}"
        # 国内外双线防拉取失败保障
        wget -q --show-progress -O /usr/local/bin/cloudflared "https://ghp.ci/${cf_url}" 2>/dev/null || wget -q --show-progress -O /usr/local/bin/cloudflared "${cf_url}"
        
        chmod +x /usr/local/bin/cloudflared
        echo -e "${green}✅ cloudflared 引擎安装完成！${plain}"
    else
        echo -e "${green}✅ 检测到 cloudflared 已安装。${plain}"
    fi

    # 2. 交互式网站授权环节
    echo -e "\n${yellow}正在检查 CF 授权凭证...${plain}"
    if [ ! -f ~/.cloudflared/cert.pem ]; then
        echo -e "${magenta}======================================================${plain}"
        echo -e "${yellow}⚠️ 接下来屏幕上将会弹出一个 Cloudflare 的授权网址。${plain}"
        echo -e "${yellow}👉 步骤 1：请【复制该网址】到你的电脑或手机浏览器中打开。${plain}"
        echo -e "${yellow}👉 步骤 2：登录你的 Cloudflare 账号，并在网页上选择你要绑定的域名。${plain}"
        echo -e "${yellow}👉 步骤 3：授权成功后，此终端界面会自动检测并继续往下执行！${plain}"
        echo -e "${magenta}======================================================${plain}"
        sleep 3
        
        # 呼出官方授权指令（阻塞式，用户在网页上点确认后才会继续）
        cloudflared tunnel login
    else
        echo -e "${green}✅ 检测到已存在授权凭证 (cert.pem)，无需重复登录。${plain}"
    fi

    # 3. 创建隧道及分配 DNS
    echo -e "\n${cyan}--- 隧道注册配置 ---${plain}"
    read -rp "请输入你要创建的隧道名称 (如 v2bx-node1): " tunnel_name
    [[ -z "$tunnel_name" ]] && tunnel_name="v2bx-node1"

    echo -e "${yellow}正在向 Cloudflare 网络注册隧道...${plain}"
    # 忽略已存在的报错，捕获新创建的日志
    cloudflared tunnel create "$tunnel_name" >/tmp/cf_create.log 2>&1
    
    # 提取隧道 UUID
    local tunnel_id
    tunnel_id=$(cloudflared tunnel list | grep -w "$tunnel_name" | awk '{print $1}')
    
    if [[ -z "$tunnel_id" ]]; then
        echo -e "${red}❌ 隧道创建失败！请检查名称是否冲突或网络连接状态。${plain}"
        cat /tmp/cf_create.log
        exit 1
    fi
    echo -e "${green}✅ 隧道创建成功！分配的 UUID: ${tunnel_id}${plain}"

    read -rp "请输入你要绑定给该节点的 CF 域名 (例如: cdn.yourdomain.com): " cf_domain
    echo -e "${yellow}正在将该域名 CNAME 路由至隧道...${plain}"
    cloudflared tunnel route dns "$tunnel_name" "$cf_domain" 2>/dev/null

    read -rp "请输入你原本 V2bX 面板节点的【本地监听端口】(默认为 20026): " local_port
    [[ -z "$local_port" ]] && local_port=20026

    # 4. 生成系统级配置文件
    echo -e "${yellow}正在生成系统级路由隧道配置文件...${plain}"
    mkdir -p /etc/cloudflared
    cat <<EOF > /etc/cloudflared/config.yml
tunnel: $tunnel_id
credentials-file: /root/.cloudflared/${tunnel_id}.json
ingress:
  - hostname: $cf_domain
    service: http://localhost:$local_port
  - service: http_status:404
EOF

    # 5. 注册为开机自启系统服务
    echo -e "${yellow}正在将 CF Tunnel 注册为系统级后台守护进程...${plain}"
    cloudflared service uninstall >/dev/null 2>&1 || true
    cloudflared service install >/dev/null 2>&1
    systemctl daemon-reload
    systemctl restart cloudflared
    systemctl enable cloudflared >/dev/null 2>&1

    echo -e "\n${green}🎉 Cloudflare Argo Tunnel (隧道节点) 部署大功告成！${plain}"
    echo -e "${magenta}------------------------------------------------------${plain}"
    echo -e "你的节点现在已被 Cloudflare 堡垒级安全接管："
    echo -e "外网访问入口 (公网穿透): ${cyan}https://${cf_domain}${plain}"
    echo -e "本地被动转发 (数据落地): ${cyan}http://localhost:${local_port}${plain}"
    echo -e "${magenta}------------------------------------------------------${plain}"
    echo -e "${yellow}💡 【面板防爆提示】${plain}"
    echo -e "1. 请在前端面板将该节点的传输协议设置为 ${cyan}WS (WebSocket)${plain}。"
    echo -e "2. ${red}千万不要${plain}在面板节点里配置 TLS（因为 CF 已经帮你套上了超强 TLS，不要套娃，否则会握手失败）。"
    echo -e "3. 面板里的节点 IP 填该域名即可，无需真实公网 IP。"
}


# ==========================================
# 主程序：交互式分支选择
# ==========================================
echo -e "\n${cyan}====================================================${plain}"
echo -e "  ${green}麦卖云 V2bX 节点配置进阶工具箱 (xmm3)${plain}"
echo -e "${cyan}====================================================${plain}"
echo -e "  ${green}1.${plain} 📁 在现有配置上，继续增量追加常规节点"
echo -e "  ${green}2.${plain} 🛡️ 部署 Cloudflare 隧道，将节点升级为无视封锁的内网穿透节点"
echo -e "${cyan}----------------------------------------------------${plain}"
read -rp "请输入操作选项 [1-2]: " mode_choice

case "$mode_choice" in
    1)
        append_nodes
        ;;
    2)
        setup_cf_tunnel
        ;;
    *)
        echo -e "${red}未知选项，退出向导。${plain}"
        exit 1
        ;;
esac
