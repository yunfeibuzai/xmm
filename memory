#!/bin/bash

# 1. 终端颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;36m'
PLAIN='\033[0m'

# 2. 权限检查
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}错误：请以 root 用户运行此脚本！${PLAIN}"
    exit 1
fi

# 3. 自动检测 V2bX 服务环境 (支持 Systemd 与 OpenRC)
INIT_TYPE="systemd"
if [ -f "/etc/systemd/system/V2bX.service" ]; then
    SERVICE_FILE="/etc/systemd/system/V2bX.service"
    SERVICE_NAME="V2bX"
elif [ -f "/etc/systemd/system/v2bx.service" ]; then
    SERVICE_FILE="/etc/systemd/system/v2bx.service"
    SERVICE_NAME="v2bx"
elif [ -f "/etc/init.d/V2bX" ]; then
    INIT_TYPE="openrc"
    SERVICE_FILE="/etc/init.d/V2bX"
    SERVICE_NAME="V2bX"
else
    echo -e "${RED}错误：未找到 V2bX 服务文件，请确认该节点已正确安装。${PLAIN}"
    exit 1
fi

clear
echo -e "${GREEN}=================================================${PLAIN}"
echo -e "${GREEN}       V2bX 资源护卫与内存调度引擎 (独立版)      ${PLAIN}"
echo -e "${GREEN}=================================================${PLAIN}"
echo -e " 1. 🟢 软性优化内存 (提升底层回收率，大流量高并发首选)"
echo -e " 2. 🟡 硬性限制内存 (防 OOM 崩溃，设定 V2bX 物理上限)"
echo -e " 3. 🟠 硬性限制 CPU (防 CPU 占用过高导致主机被封)"
echo -e " 4. ⚪ 还原默认配置 (解绑满血狂飙，清除所有限制)"
echo -e " 0. 退出脚本"
echo -e "${GREEN}=================================================${PLAIN}"
read -p "请选择操作 [0-4]: " Choice < /dev/tty

# 精细化清理逻辑（防止内存和 CPU 设置互相覆盖）
clean_mem_limits() {
    if [ "$INIT_TYPE" = "systemd" ]; then
        sed -i '/Environment="*GOGC/d; /Environment="*GOMEMLIMIT/d' "$SERVICE_FILE"
        sed -i '/Environment=GOGC/d; /Environment=GOMEMLIMIT/d' "$SERVICE_FILE"
        sed -i '/MemoryMax=/d; /MemoryHigh=/d; /MemorySwapMax=/d; /OOMScoreAdjust=/d' "$SERVICE_FILE"
    else
        sed -i '/export GOGC=/d; /export GOMEMLIMIT=/d' "$SERVICE_FILE"
    fi
}

clean_cpu_limits() {
    if [ "$INIT_TYPE" = "systemd" ]; then
        sed -i '/CPUQuota=/d; /Nice=/d' "$SERVICE_FILE"
    else
        sed -i '/start_stop_daemon_args=/d' "$SERVICE_FILE"
    fi
}

# 重启服务模块
restart_service() {
    echo -e "${YELLOW}\n正在重载配置并重启 ${SERVICE_NAME} 服务...${PLAIN}"
    if [ "$INIT_TYPE" = "systemd" ]; then
        systemctl daemon-reload
        systemctl restart "$SERVICE_NAME"
        sleep 1.5
        if systemctl is-active --quiet "$SERVICE_NAME"; then
            echo -e "${GREEN}配置已成功生效！${PLAIN}"
        else
            echo -e "${RED}警告：服务重启失败，请运行 journalctl -u ${SERVICE_NAME} -n 20 查看原因。${PLAIN}"
        fi
    else
        rc-service "$SERVICE_NAME" restart
        echo -e "${GREEN}配置已成功生效！${PLAIN}"
    fi
}

case "$Choice" in
    1)
        TOTAL_MEM=$(free -m | awk '/^Mem:/{print $2}')
        if [ -z "$TOTAL_MEM" ] || [ "$TOTAL_MEM" -eq 0 ]; then
            TOTAL_MEM=$(cat /proc/meminfo | grep MemTotal | awk '{print $2}')
            TOTAL_MEM=$((TOTAL_MEM / 1024))
        fi
        # 针对多用户高并发，将默认安全线从 70% 提高到 80%，留足连接缓冲区
        LIMIT_MEM=$((TOTAL_MEM * 80 / 100))
        
        echo -e "\n当前服务器总内存: ${BLUE}${TOTAL_MEM} MB${PLAIN}"
        echo -e "${YELLOW}提示：大流量/多用户节点建议将释放线设得宽松些（如推荐的 80% 以上），防止高峰期 GC 过于频繁榨干 CPU。${PLAIN}"
        read -p "请输入软性回收触发线 (单位 MiB, 直接回车使用推荐值 ${LIMIT_MEM}): " USER_LIMIT < /dev/tty
        [ -z "$USER_LIMIT" ] && USER_LIMIT=$LIMIT_MEM
        if ! [[ "$USER_LIMIT" =~ ^[0-9]+$ ]]; then echo -e "${RED}输入错误！${PLAIN}"; exit 1; fi
        
        clean_mem_limits
        if [ "$INIT_TYPE" = "systemd" ]; then
            # 只注入 GOMEMLIMIT 水位线防守，移除 GOGC=50，让 Go 保持最高效率、防高负载时 CPU 暴涨
            sed -i "/\[Service\]/a Environment=\"GOMEMLIMIT=${USER_LIMIT}MiB\"" "$SERVICE_FILE"
        else
            sed -i "/description=/a export GOMEMLIMIT=${USER_LIMIT}MiB" "$SERVICE_FILE"
        fi
        echo -e "${GREEN}软性内存回收策略已注入（已自动规避多用户并发下的 CPU 颠簸风险）。${PLAIN}"
        restart_service
        ;;
        
    2)
        if [ "$INIT_TYPE" = "openrc" ]; then
            echo -e "${RED}抱歉，OpenRC (Alpine 系统) 暂不支持内核级 MemoryMax 强限制，请使用选项 1 进行软限制。${PLAIN}"
            exit 1
        fi
        
        echo -e "\n${YELLOW}提示：硬限制会强制杀掉超出内存的连接，保证 VPS 不会失联。${PLAIN}"
        read -p "请输入允许 V2bX 使用的最大内存上限 (单位 MiB, 例如 128): " HARD_LIMIT < /dev/tty
        if ! [[ "$HARD_LIMIT" =~ ^[0-9]+$ ]]; then echo -e "${RED}输入错误！${PLAIN}"; exit 1; fi
        HIGH_LIMIT=$((HARD_LIMIT * 8 / 10))
        
        clean_mem_limits
        sed -i "/\[Service\]/a Environment=\"GOMEMLIMIT=${HARD_LIMIT}MiB\"" "$SERVICE_FILE"
        sed -i "/\[Service\]/a Environment=\"GOGC=80\"" "$SERVICE_FILE"
        sed -i "/\[Service\]/a MemoryMax=${HARD_LIMIT}M" "$SERVICE_FILE"
        sed -i "/\[Service\]/a MemoryHigh=${HIGH_LIMIT}M" "$SERVICE_FILE"
        sed -i "/\[Service\]/a MemorySwapMax=0" "$SERVICE_FILE"
        sed -i "/\[Service\]/a OOMScoreAdjust=-100" "$SERVICE_FILE"
        
        echo -e "${GREEN}硬性内存防爆锁已注入。${PLAIN}"
        restart_service
        ;;
        
    3)
        if [ "$INIT_TYPE" = "openrc" ]; then
            echo -e "${RED}抱歉，OpenRC (Alpine 系统) 暂不支持内核级 CPUQuota 限制。${PLAIN}"
            exit 1
        fi
        
        echo -e "\n${YELLOW}提示：限制 CPU 可有效防止机场大流量导致小鸡 CPU 长期 100% 被主机商封禁。${PLAIN}"
        read -p "请输入允许 V2bX 使用的最大 CPU 占用比 (例如填 40 代表 40%): " CPU_LIMIT < /dev/tty
        if ! [[ "$CPU_LIMIT" =~ ^[0-9]+$ ]]; then echo -e "${RED}输入错误！${PLAIN}" ; exit 1; fi
        
        clean_cpu_limits
        sed -i "/\[Service\]/a CPUQuota=${CPU_LIMIT}%" "$SERVICE_FILE"
        sed -i "/\[Service\]/a Nice=19" "$SERVICE_FILE"
        
        echo -e "${GREEN}CPU 压制锁已注入。${PLAIN}"
        restart_service
        ;;
        
    4)
        clean_mem_limits
        clean_cpu_limits
        echo -e "${GREEN}已成功清除所有内存与 CPU 限制参数。${PLAIN}"
        restart_service
        ;;
        
    0)
        exit 0
        ;;
        
    *)
        echo -e "${RED}未知选项！${PLAIN}"
        exit 1
        ;;
esac
