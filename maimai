# 🌟 已精准重构：完全剥离出本地，实现全自动远程云调度
make_full_config() {
    echo -e "${cyan}正在从麦卖云秘密仓库拉取最新向导引擎...${plain}"
    local remote_wizard_url="https://raw.githubusercontent.com/yunfeibuzai/xmm/main/xmm2"
    local proxy_wizard_url="https://ghp.ci/https://raw.githubusercontent.com/yunfeibuzai/xmm/main/xmm2"
    
    # 双重保险下载逻辑，增加镜像源防止墙
    wget -O /tmp/xmm2 "$proxy_wizard_url" --timeout=10 2>/dev/null || wget -O /tmp/xmm2 "$remote_wizard_url" --timeout=10 2>/dev/null || curl -sL "$remote_wizard_url" -o /tmp/xmm2
    
    if [[ -f /tmp/xmm2 && -s /tmp/xmm2 ]]; then
        chmod +x /tmp/xmm2
        bash /tmp/xmm2  # 独立沙箱安全运行，防变量污染
        rm -f /tmp/xmm2
    else
        echo -e "${red}错误：无法连接到云端仓库，请检查网络或确认 GitHub 上的 xmm2 文件是否存在！${plain}"
    fi
}

self_install_core() {
    echo -e "${yellow}正在安全部署麦卖云全功能核心组件...${plain}"
    
    # 停止已有服务并清理旧文件
    systemctl stop V2bX >/dev/null 2>&1
    systemctl disable V2bX >/dev/null 2>&1
    killall -9 V2bX >/dev/null 2>&1
    mkdir -p /usr/local/V2bX /etc/V2bX
    rm -rf /usr/local/V2bX/V2bX /tmp/v2bx_tmp*

    local arch=$(uname -m)
    case "${arch}" in 
        x86_64 | amd64) arch="linux-64" ;; 
        arm64 | aarch64) arch="linux-arm64-v8a" ;; 
        *) arch="linux-64" ;; 
    esac
    
    # 获取最新版本，若失败则默认 v0.3.9
    local last_version=$(curl -sL "https://api.github.com/repos/wyx2685/V2bX/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
    [[ -z "$last_version" ]] && last_version="v0.3.9"

    # 替换已失效的 ghproxy.com，增加备用镜像节点
    local urls=(
        "https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
        "https://ghp.ci/https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
        "https://mirror.ghproxy.net/https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
        "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/V2bX-linux-64.zip"
    )

    local success=false
    for url in "${urls[@]}"; do
        echo -e "${yellow}探测拉取线: ${url}${plain}"
        local tmp_file="/tmp/v2bx_tmp_${RANDOM}.zip"
        
        # 移除导致无法排错的 2>/dev/null，让用户能看到下载是成功还是 404
        wget -q --show-progress -O "$tmp_file" "$url" --timeout=15 

        if [[ -f "$tmp_file" && -s "$tmp_file" ]]; then
            # 校验是否为 ZIP 文件
            if head -c 4 "$tmp_file" | grep -q 'PK'; then
                local tmp_dir="/tmp/v2bx_extract_${RANDOM}"
                mkdir -p "$tmp_dir"
                unzip -q -o "$tmp_file" -d "$tmp_dir"
                
                # 寻找解压出来的二进制文件
                local b_target=""
                [[ -f "$tmp_dir/V2bX" ]] && b_target="$tmp_dir/V2bX"
                [[ -f "$tmp_dir/V2bX-${arch}" ]] && b_target="$tmp_dir/V2bX-${arch}"
                [[ -f "$tmp_dir/V2bX-linux-64" ]] && b_target="$tmp_dir/V2bX-linux-64"
                
                if [[ -n "$b_target" && -f "$b_target" ]] && head -c 4 "$b_target" | grep -q 'ELF'; then
                    mv -f "$b_target" /usr/local/V2bX/V2bX && success=true
                fi
                rm -rf "$tmp_dir"
            elif head -c 4 "$tmp_file" | grep -q 'ELF'; then
                # 如果直接下载的就是二进制文件
                mv -f "$tmp_file" /usr/local/V2bX/V2bX && success=true
            fi
        fi
        rm -f "$tmp_file"
        
        if [ "$success" = true ]; then
            chmod +x /usr/local/V2bX/V2bX
            echo -e "${green}[成功] 核心拉取成功并已通过 ELF 二进制合法性校验！${plain}"
            break
        fi
    done

    if [ "$success" = false ]; then
        echo -e "${red}[错误] 所有拉取线路均失败，请检查服务器网络或 DNS 设置！${plain}"
        return
    fi

    # 替换失效代理获取规则文件
    echo -e "${cyan}正在拉取路由规则文件...${plain}"
    wget -q -O /usr/local/V2bX/geoip.dat "https://ghp.ci/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat" || wget -q -O /usr/local/V2bX/geoip.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat"
    wget -q -O /usr/local/V2bX/geosite.dat "https://ghp.ci/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat" || wget -q -O /usr/local/V2bX/geosite.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat"

    if [ ! -f /etc/V2bX/config.json ]; then
        read -rp "未检测到配置文件，是否立即生成？(y/n) " ask_gen_config
        if [[ "$ask_gen_config" == "y" || "$ask_gen_config" == "Y" ]]; then
            make_full_config
        else
            echo -e "${yellow}[警告] 跳过配置文件生成。服务将无法启动，请务必后续手动配置！${plain}"
        fi
    fi

    # 增加 RestartSec 缓冲，防止无配置时的 CPU 爆满
    cat << EOF > /etc/systemd/system/V2bX.service
[Unit]
Description=V2bX Service
After=network.target

[Service]
ExecStart=/usr/local/V2bX/V2bX server -c /etc/V2bX/config.json
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload 
    systemctl enable V2bX >/dev/null 2>&1 
    
    # 仅当配置文件存在时才尝试拉起服务
    if [ -f /etc/V2bX/config.json ]; then
        systemctl restart V2bX
        echo -e "${green}V2bX 服务已注册成功并尝试拉起运转。${plain}"
    else
        echo -e "${yellow}V2bX 已安装，但由于缺少 config.json，服务处于暂停状态，请配置后启动。${plain}"
    fi
}

make_advanced_modules() {
    echo -e "\n${yellow}========== 进阶：高级外部功能矩阵配置生成器 ==========${plain}"
    echo -e " [1] 生成 Sing-box 自定义策略路由组件 (sing_origin.json)"
    echo -e " [2] 生成 Xray 自定义高级 DNS 解锁组件 (dns.json)"
    echo -e " [3] 生成 Xray 强审计自定义拦截路由组件 (route.json)"
    echo -e " [4] 生成 Xray 多端本地入站与自由出口拦截器"
    read -rp "请做出你的选择 [1-4]: " am_num
    case "$am_num" in
    1)
cat << 'EOF' > /etc/V2bX/sing_origin.json
{
"dns": { "servers": [ { "tag": "cloudflare", "address": "1.1.1.1", "strategy": "prefer_ipv4" } ] },
"outbounds": [ { "tag": "direct", "type": "direct", "domain_strategy": "prefer_ipv4" } ],
"route": { "rules": [ { "ip_is_private": true, "action": "reject" }, { "rule_set": [ "geosite-category-ads-all" ], "action": "reject" } ] }
}
EOF
        echo -e "${green}[成功] /etc/V2bX/sing_origin.json 生成完毕！${plain}"
        ;;
    2)
cat << 'EOF' > /etc/V2bX/dns.json
{ "servers": [ "8.8.8.8", { "address": "1.1.2.2", "port": 53, "domains": [ "geosite:netflix" ] } ] }
EOF
        echo -e "${green}[成功] /etc/V2bX/dns.json 优先解锁模板组装完毕！${plain}"
        ;;
    3)
cat << 'EOF' > /etc/V2bX/route.json
{ "domainStrategy": "IPOnDemand", "rules": [ { "type": "field", "outboundTag": "block", "ip": [ "geoip:private" ] }, { "type": "field", "outboundTag": "block", "protocol": [ "bittorrent" ] } ] }
EOF
        echo -e "${green}[成功] /etc/V2bX/route.json 防BT审计策略阻断落盘！${plain}"
        ;;
    4)
cat << 'EOF' > /etc/V2bX/custom_inbound.json
[ { "listen": "0.0.0.0", "port": 1234, "protocol": "socks", "settings": { "auth": "noauth", "udp": false } } ]
EOF
cat << 'EOF' > /etc/V2bX/custom_outbound.json
[ { "tag": "IPv4_out", "protocol": "freedom" }, { "protocol": "blackhole", "tag": "block" } ]
EOF
        echo -e "${green}[成功] 入站与黑洞出口拦截器同步挂载完成！${plain}"
        ;;
    esac
}

install_bbr() { wget -O tcp.sh --no-check-certificate "https://github.com/ylx2016/Linux-NetSpeed/raw/master/tcp.sh" && chmod +x tcp.sh && ./tcp.sh; }
update_shell() { curl -o /usr/local/bin/maimai_core.sh -Ls "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/maimai" && register_shortcut; echo -e "${green}脚本升级成功！${plain}"; exit 0; }
open_ports() { iptables -P INPUT ACCEPT && iptables -P FORWARD ACCEPT && iptables -P OUTPUT ACCEPT && iptables -F; echo -e "${green}已放行所有网络端口${plain}"; }
run_clean_script() { free -h; sync && echo 3 > /proc/sys/vm/drop_caches 2>/dev/null; echo -e "${green}系统残留空间已强制净化完毕${plain}"; }
run_deep_log_clean() { find /var/log -type f -regex '.*.log' -or -regex '.*err' -or -regex '.messages' | while read -r log; do cat /dev/null > "$log" 2>/dev/null; done; echo -e "${green}大日志清理完毕${plain}"; }

# 🌟 精准修复：补齐 5 个星号，健壮性安全判断写入状态
start_daemon() { 
    cat << 'EOF' > /usr/local/bin/V2bX_daemon.sh
#!/bin/bash
systemctl is-active --quiet V2bX || (systemctl daemon-reload && systemctl start V2bX)
EOF
    chmod +x /usr/local/bin/V2bX_daemon.sh
    if (crontab -l 2>/dev/null | grep -v "V2bX_daemon"; echo "* * * * * /bin/bash /usr/local/bin/V2bX_daemon.sh >/dev/null 2>&1") | crontab -; then
        echo -e "${green}自动化自愈守护已成功开启！${plain}"
    else
        echo -e "${red}错误：定时任务写入失败，请检查系统 crontab 组件是否安装正常！${plain}"
    fi
}

stop_daemon() { 
    crontab -l 2>/dev/null | grep -v "V2bX_daemon" | crontab -
    rm -f /usr/local/bin/V2bX_daemon.sh
    echo -e "${yellow}自愈守护已关闭${plain}" 
}

process_run() {
    local num; read -rp "请输入选择 [0-22]: " num
    case "$num" in
    0) nano /etc/V2bX/config.json && systemctl daemon-reload && systemctl restart V2bX ;; 
    1|2) self_install_core ;; 
    3) rm -rf /usr/local/V2bX /etc/V2bX /etc/systemd/system/V2bX.service && echo "卸载完成" ;;
    4) systemctl daemon-reload && systemctl start V2bX ;; 
    5) systemctl stop V2bX ;; 
    6) systemctl daemon-reload && systemctl reset-failed V2bX && systemctl restart V2bX ;; 
    7) systemctl status V2bX ;; 
    8) journalctl -u V2bX -n 50 --no-pager ;;
    9) systemctl enable V2bX ;; 
    10) systemctl disable V2bX ;; 
    11) make_full_config ;; 
    12) make_advanced_modules ;; 
    13) /usr/local/V2bX/V2bX x25519 ;;
    14) update_shell ;; 
    15) start_daemon ;; 
    16) stop_daemon ;; 
    17) install_bbr ;; 
    18) open_ports ;; 
    19) run_clean_script ;; 
    20) run_deep_log_clean ;;
    21) uname -a && free -m && df -h ;; 
    22) exit 0 ;; 
    *) echo -e "${red}未知序号${plain}" ;;
    esac
}

while true; do show_menu; process_run; echo ""; read -rp "按回车键返回主菜单..." ; done
