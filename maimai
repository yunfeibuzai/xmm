red='\033[31m'; green='\033[32m'; yellow='\033[33m'
magenta='\033[35m'; cyan='\033[36m'; plain='\033[0m'

[[ $EUID -ne 0 ]] && echo -e "${red}错误：${plain}必须使用root用户运行此脚本！\n" && exit 1

# 🌟 基础依赖自动补齐
install_dependencies() {
    local cmds=("wget" "curl" "tar" "unzip" "jq" "nano")
    local needs_install=false

    for cmd in "${cmds[@]}"; do
        if ! command -v "$cmd" &>/dev/null; then
            needs_install=true
            break
        fi
    done

    if command -v apk &>/dev/null; then
        if ! apk info -e gcompat &>/dev/null || ! apk info -e libc6-compat &>/dev/null; then
            needs_install=true
        fi
    fi

    if [ "$needs_install" = true ]; then
        echo -e "${yellow}正在检查并补齐系统基础依赖与架构兼容层...${plain}"
        if command -v apt-get &>/dev/null; then
            apt-get update -y -q >/dev/null 2>&1
            apt-get install -y --no-install-recommends wget curl tar unzip jq nano >/dev/null 2>&1
        elif command -v yum &>/dev/null; then
            yum install -y epel-release >/dev/null 2>&1
            yum install -y wget curl tar unzip jq nano >/dev/null 2>&1
        elif command -v apk &>/dev/null; then
            apk add --no-cache wget curl tar unzip jq nano gcompat libc6-compat >/dev/null 2>&1
        fi
    fi
}
install_dependencies

# 🌟 快捷命令注册
register_shortcut() {
    mkdir -p /usr/local/bin
    rm -f /usr/bin/maimai /usr/bin/v2bx
    
    if [[ -f "$0" ]]; then
        local current_abs_path
        current_abs_path=$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")
        if [[ "$current_abs_path" != "/usr/local/bin/maimai_core.sh" ]]; then
            rm -f /usr/local/bin/maimai_core.sh
            cp -f "$current_abs_path" /usr/local/bin/maimai_core.sh
            chmod +x /usr/local/bin/maimai_core.sh
        fi
    fi
    
    if [[ -f /usr/local/bin/maimai_core.sh ]]; then
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/maimai
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/v2bx
        chmod +x /usr/bin/maimai /usr/bin/v2bx
    fi
}
register_shortcut

# 🌟 智能内核服务管理器
manage_service() {
    local action=$1
    if command -v systemctl &>/dev/null; then
        case "$action" in
            start) systemctl start V2bX ;;
            stop) systemctl stop V2bX ;;
            restart) systemctl restart V2bX ;;
            status) systemctl status V2bX ;;
            enable) systemctl enable V2bX >/dev/null 2>&1 ;;
            disable) systemctl disable V2bX >/dev/null 2>&1 ;;
            logs) journalctl -u V2bX -n 50 --no-pager ;;
        esac
    elif command -v rc-service &>/dev/null; then
        case "$action" in
            start) rc-service V2bX start ;;
            stop) rc-service V2bX stop ;;
            restart) rc-service V2bX restart ;;
            status) rc-service V2bX status ;;
            enable) rc-update add V2bX default >/dev/null 2>&1 ;;
            disable) rc-update del V2bX default >/dev/null 2>&1 ;;
            logs) 
                if [ -f /var/log/v2bx_err.log ]; then 
                    tail -n 50 /var/log/v2bx_err.log
                else 
                    echo -e "${yellow}暂无错误日志汇总或服务未曾崩溃${plain}"
                fi 
                ;;
        esac
    fi
}

show_status() {
    local core_status="${red}未安装${plain}"
    local guard_status="${yellow}未开启 (原生态无锁)${plain}"

    if [[ -f /usr/local/V2bX/V2bX && -s /usr/local/V2bX/V2bX ]]; then
        if command -v systemctl &>/dev/null; then
            if systemctl is-active --quiet V2bX 2>/dev/null; then
                core_status="${green}运行中${plain}"
            else
                core_status="${yellow}已停止${plain}"
            fi
            if grep -q "MemoryMax" /etc/systemd/system/V2bX.service 2>/dev/null || grep -q "GOMEMLIMIT" /etc/systemd/system/V2bX.service 2>/dev/null; then
                guard_status="${green}内核级防爆已开启${plain}"
            fi
        elif command -v rc-service &>/dev/null; then
            local rc_out
            rc_out=$(rc-service V2bX status 2>/dev/null)
            if echo "$rc_out" | grep -q "started"; then
                core_status="${green}运行中${plain}"
            elif echo "$rc_out" | grep -q "crashed"; then
                core_status="${red}已崩溃${plain}"
            else
                core_status="${yellow}已停止${plain}"
            fi
            if grep -q "GOMEMLIMIT" /etc/init.d/V2bX 2>/dev/null; then
                guard_status="${green}内核级防爆已开启${plain}"
            fi
        fi
    fi

    echo -e "V2bX 状态: $core_status | 资源护卫: $guard_status"
}

