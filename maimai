    clear
    echo -e "  ${green}麦 卖 云  V2bX 后 端 全 能 王 牌 脚 本${plain}  (NAT/LXC 终 极 守 护 版)"
    echo -e "--- 快捷命令: ${cyan}maimai${plain} 或 ${cyan}v2bx${plain} ---"
    echo -e "  ${green}0.${plain} 修 改 配 置  (智 能 调 用 精 简 编 辑 器)"
    echo -e "————————————————"
    echo -e "  ${green}1.${plain} 安 装  V2bX (自动重构完整核心)    ${green}2.${plain} 更 新  V2bX"
    echo -e "  ${green}3.${plain} 卸 载  V2bX                      ${green}4.${plain} 启 动  V2bX"
    echo -e "  ${green}5.${plain} 停 止  V2bX                      ${green}6.${plain} 重 启  V2bX (强 杀 顽 固 僵 尸)"
    echo -e "  ${green}7.${plain} 查 看  V2bX 状 态                 ${green}8.${plain} 查 看  V2bX 日 志"
    echo -e "————————————————"
    echo -e "  ${green}9.${plain} 设 置  V2bX 开 机 自 启             ${green}10.${plain} 取 消  V2bX 开机自启"
    echo -e "  ${green}11.${plain} 🚀 豪 华 版  BBR 控 制 台            ${green}12.${plain} 查 看  V2bX 版 本"
    echo -e "  ${green}13.${plain} 生 成  x25519 密 钥               ${green}14.${plain} 升 级  V2bX 维 护 脚 本"
    echo -e "  ${green}15.${plain} 交互式一键生成/重写配置文件"
    echo -e "————————————————"
    echo -e "  ${green}16.${plain} 麦 卖 云 小 鸡 体 检 与 残 留 挂机 容 器 强 杀"
    echo -e "  ${green}17.${plain} 放 行  VPS 的 所 有 网 络 端 口  (iptables 净化)"
    echo -e "  ${green}18.${plain} 彻 底 退 出 脚 本"
    echo -e "————————————————"
    echo -e "  ${magenta}[专 属 高 可 用 核 心 快 捷 功 能 群]${plain}"
    echo -e "  ${green}19.${plain} 小 鸡 网 络 延 迟 与 流 媒 体 丢 包 极 速 测 试"
    echo -e "  ${green}20.${plain} 强 制 清 空 系 统 死 锁 大 日 志 与 残 留 垃 圾 缓 存"
    echo -e "  ${green}21.${plain} 🟢 开 启  自 动化 守 护  (死 机 自 动 秒 拉 起)"
    echo -e "  ${green}22.${plain} 🔴 关 闭  自 动化 守 护"
    echo -e "  ${green}23.${plain} 🔍 查 看 当 前 小 鸡 所 有 硬 件 信 息 看 看 板"
    echo -e "————————————————"
