#!/bin/bash

# 麦卖云 V2bX 后端全能王牌脚本 (特卡去脂版 + 安全自愈守护 + 快捷键修复版)
sh_ver="4.0.0"

red='\033[31m'; green='\033[32m'; yellow='\033[33m'
magenta='\033[35m'; cyan='\033[36m'; plain='\033[0m'

[[ $EUID -ne 0 ]] && echo -e "${red}错误：${plain}必须使用root用户运行此脚本！\n" && exit 1

# 🌟 基础依赖自动补齐
install_dependencies() {
    local cmds=("wget" "curl" "tar" "unzip" "jq" "nano")
    local needs_install=false

    for cmd in "${cmds[@]}"; do
        if ! command -v "$cmd" &>/dev/null; then
            needs_install=true
            break
        fi
    done

    if [ "$needs_install" = true ]; then
        echo -e "${yellow}正在检查并补齐系统基础依赖...${plain}"
        if command -v apt-get &>/dev/null; then
            apt-get update -y >/dev/null 2>&1
            apt-get install -y wget curl tar unzip jq nano >/dev/null 2>&1
        elif command -v yum &>/dev/null; then
            yum install -y epel-release >/dev/null 2>&1
            yum install -y wget curl tar unzip jq nano >/dev/null 2>&1
        elif command -v apk &>/dev/null; then
            apk add --no-cache wget curl tar unzip jq nano >/dev/null 2>&1
        fi
    fi
}
install_dependencies

# 🌟 快捷命令注册 (斩断 "are the same file" 自复制循环死锁)
register_shortcut() {
    mkdir -p /usr/local/bin
    
    # 1. 彻底解开引用链，强删潜在冲突路径
    rm -f /usr/bin/maimai
    rm -f /usr/bin/v2bx
    
    # 2. 只有当前执行路径不是目标核心路径时，才执行覆盖拷贝
    if [[ -f "$0" ]]; then
        local current_abs_path
        current_abs_path=$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")
        if [[ "$current_abs_path" != "/usr/local/bin/maimai_core.sh" ]]; then
            rm -f /usr/local/bin/maimai_core.sh
            cp -f "$current_abs_path" /usr/local/bin/maimai_core.sh
            chmod +x /usr/local/bin/maimai_core.sh
        fi
    fi
    
    # 3. 干净重建符号链接
    if [[ -f /usr/local/bin/maimai_core.sh ]]; then
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/maimai
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/v2bx
        chmod +x /usr/bin/maimai /usr/bin/v2bx
    fi
}
register_shortcut

