#!/bin/bash

# 麦卖云 V2bX 后端全能王牌脚本 (压缩包自动化解压版)
sh_ver="2.7.0"

red='\033[0;31m'; green='\033[0;32m'; yellow='\033[0;33m'
magenta='\033[0;35m'; cyan='\033[0;36m'; plain='\033[0m'

[[ $EUID -ne 0 ]] && echo -e "${red}错误：${plain}必须使用root用户运行此脚本！\n" && exit 1

# 自动安装解压工具
echo -e "${yellow}正在检查并优化基础解压依赖工具环境...${plain}"
for cmd in wget curl tar unzip; do
    if ! command -v $cmd &>/dev/null; then
        apt-get update && apt-get install -y $cmd || yum install -y $cmd || apk add --no-cache $cmd
    fi
done

register_shortcut() {
    mkdir -p /usr/local/bin
    if [[ "$0" != "/usr/local/bin/maimai_core.sh" && -f "$0" ]]; then
        cp -f "$0" /usr/local/bin/maimai_core.sh
        chmod +x /usr/local/bin/maimai_core.sh
    fi
    rm -f /usr/bin/maimai /usr/bin/v2bx
    if [[ -f /usr/local/bin/maimai_core.sh ]]; then
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/maimai
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/v2bx
        chmod +x /usr/bin/maimai /usr/bin/v2bx
    fi
}
register_shortcut

show_status() {
    if [[ ! -f /usr/local/V2bX/V2bX ]] || [[ ! -s /usr/local/V2bX/V2bX ]]; then
        echo -e "V2bX 状态: ${red}未安装或核心已损坏 (0字节/非二进制)${plain}"
        return
    fi
    if systemctl is-active --quiet V2bX 2>/dev/null; then
        echo -e "V2bX 状态: ${green}已运行${plain}"
    else
        echo -e "V2bX 状态: ${red}未运行${plain}"
    fi
}

show_menu() {
    clear
    echo -e "${green}麦卖云 V2bX 后端全能王牌脚本${plain} (全自动解压复活版)"
    echo -e "--- 快捷命令: ${cyan}maimai${plain} ---"
    echo -e "  ${green}0.${plain} 修改配置"
    echo -e "————————————————"
    echo -e "  ${green}1.${plain} 安装 V2bX (自动解压官方最新版)      ${green}2.${plain} 更新 V2bX"
    echo -e "  ${green}3.${plain} 卸载 V2bX                        ${green}4.${plain} 启动 V2bX"
    echo -e "  ${green}5.${plain} 停止 V2bX                        ${green}6.${plain} 重启 V2bX"
    echo -e "  ${green}7.${plain} 查看 V2bX 状态                   ${green}8.${plain} 查看 V2bX 日志"
    echo -e "————————————————"
    echo -e "  ${green}11.${plain} 🚀 豪华版 BBR 控制台              ${green}12.${plain} 查看 V2bX 版本"
    echo -e "  ${green}16.${plain} 麦卖云小鸡体检与残留挂机容器强杀"
    echo -e "  ${green}20.${plain} 强制清空系统死锁大日志与残留垃圾缓存"
    echo -e "  ${green}24.${plain} 🧹 专门清空 V2bX 自身的运行日志"
    echo -e "————————————————"
    show_status
}

check_status() {
    if [[ ! -f /usr/local/V2bX/V2bX ]] || [[ ! -s /usr/local/V2bX/V2bX ]]; then return 2; fi
    systemctl is-active --quiet V2bX && return 0 || return 1
}

make_config() {
    echo -e "\n${yellow}========== 智能节点配置向导 ==========${plain}"
    mkdir -p /etc/V2bX
    read -rp "1. 请输入机场前端对接地址 (ApiHost): " api_host
    read -rp "2. 请输入机场前端通讯密钥 (ApiKey): " api_key
    read -rp "3. 请输入该节点在机场的真实ID (NodeID): " node_id
    
    cat << EOF > /etc/V2bX/config.json
{
  "Log": { "Level": "info", "Output": "" },
  "Cores": [ { "Type": "sing", "Log": { "Level": "info", "Timestamp": true } } ],
  "Nodes": [ { "Core": "sing", "ApiHost": "${api_host}", "ApiKey": "${api_key}", "NodeID": ${node_id}, "NodeType": "VLess", "Timeout": 30, "ListenIP": "0.0.0.0", "SendIP": "0.0.0.0", "SniffEnabled": true } ]
}
EOF
}

self_install_core() {
    echo -e "${yellow}正在安全部署麦卖云原生全功能官方核心组件...${plain}"
    systemctl stop V2bX >/dev/null 2>&1
    mkdir -p /usr/local/V2bX /etc/V2bX
    rm -rf /usr/local/V2bX/V2bX /tmp/v2bx_tmp*
    
    # 🌟 针对官方最新 .zip 压缩包的高可用分发链
    local urls=(
        "https://github.com/wyx2685/V2bX/releases/latest/download/V2bX-linux-amd64.zip"
        "https://mirror.ghproxy.com/https://github.com/wyx2685/V2bX/releases/latest/download/V2bX-linux-amd64.zip"
    )
    
    local success=false

    for url in "${urls[@]}"; do
        echo -e "${yellow}正在拉取官方压缩包: ${url}${plain}"
        local tmp_zip="/tmp/v2bx_tmp_${RANDOM}.zip"
        local tmp_dir="/tmp/v2bx_extract_${RANDOM}"
        
        wget -O "$tmp_zip" "$url" --timeout=20 2>/dev/null
        
        if [[ -f "$tmp_zip" && -s "$tmp_zip" ]]; then
            # 用小鸡自带的压缩工具在临时目录静默解压
            mkdir -p "$tmp_dir"
            unzip -q -o "$tmp_zip" -d "$tmp_dir" >/dev/null 2>&1
            
            # 智能搜寻解压出来的核心文件
            local target_binary=""
            if [[ -f "$tmp_dir/V2bX" ]]; then
                target_binary="$tmp_dir/V2bX"
            elif [[ -f "$tmp_dir/V2bX-linux-amd64" ]]; then
                target_binary="$tmp_dir/V2bX-linux-amd64"
            fi
            
            # 严格防空防御：校验解压出的核心是不是真正的 ELF 二进制机器码
            if [[ -n "$target_binary" && -f "$target_binary" ]]; then
                if head -c 4 "$target_binary" | grep -q 'ELF'; then
                    mv -f "$target_binary" /usr/local/V2bX/V2bX
                    chmod +x /usr/local/V2bX/V2bX
                    echo -e "${green}[成功] 核心文件由小鸡自主解压并成功通过 ELF 二进制强校验！${plain}"
                    success=true
                    rm -rf "$tmp_zip" "$tmp_dir"
                    break
                fi
            fi
        fi
        rm -rf "$tmp_zip" "$tmp_dir"
        echo -e "${red}[警告] 当前压缩包源拉取或解压失败，正在自动切线下拉...${plain}"
    done

    if [ "$success" = false ]; then
        echo -e "${red}错误：所有官方压缩包分发源均拉取失败。请检查小鸡的网络或 DNS 设定！${plain}"
        return 1
    fi
    
    # 部署路由资源
    wget -O /usr/local/V2bX/geoip.dat "https://mirror.ghproxy.com/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat" 2>/dev/null || wget -O /usr/local/V2bX/geoip.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat" 2>/dev/null
    wget -O /usr/local/V2bX/geosite.dat "https://mirror.ghproxy.com/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat" 2>/dev/null || wget -O /usr/local/V2bX/geosite.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat" 2>/dev/null

    if [ ! -f /etc/V2bX/config.json ]; then make_config; fi

    cat << EOF > /etc/systemd/system/V2bX.service
[Unit]
Description=V2bX Service
After=network.target

[Service]
ExecStart=/usr/local/V2bX/V2bX -c /etc/V2bX/config.json
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable V2bX >/dev/null 2>&1
    systemctl restart V2bX >/dev/null 2>&1
    echo -e "${green}V2bX 核心已全自动解压并部署上线！服务已安全拉起。${plain}"
}

process_run() {
    local num; read -rp "请输入选择: " num
    case "$num" in
        0) nano /etc/V2bX/config.json ;; 
        1|2) self_install_core ;; 
        3) rm -rf /usr/local/V2bX /etc/V2bX /etc/systemd/system/V2bX.service && echo "卸载完成" ;;
        4) systemctl start V2bX && echo "已启动" ;; 
        5) systemctl stop V2bX && killall V2bX && echo "已彻底停止" ;; 
        6) systemctl restart V2bX && echo "已重启" ;; 
        7) check_status && echo -e "状态: ${green}正在运行${plain}" || echo -e "状态: ${red}未运行${plain}" ;;
        8) journalctl -u V2bX -n 30 --no-pager ;;
        11) wget -O tcp.sh --no-check-certificate "https://github.com/ylx2016/Linux-NetSpeed/raw/master/tcp.sh" && chmod +x tcp.sh && ./tcp.sh ;;
        12) /usr/local/V2bX/V2bX version 2>/dev/null || echo "官方原生核心" ;;
        16) free -h && sync && echo 3 > /proc/sys/vm/drop_caches 2>/dev/null && echo -e "${green}清理挂机残留完成${plain}" ;;
        20) find /var/log -type f -regex '.*\.log' -or -regex '.*err' -or -regex '.*messages' | while read -r log; do cat /dev/null > "$log" 2>/dev/null; done; echo -e "${green}大日志清理完毕${plain}" ;;
        24) journalctl --vacuum-time=1s >/dev/null 2>&1 && echo -e "${green}[成功] V2bX 运行日志已清空！${plain}" ;;
        *) echo -e "${red}请输入正确的数字${plain}" ;;
    esac
}

while true; do show_menu; process_run; echo ""; read -rp "按回车键返回主菜单..."  ; done
