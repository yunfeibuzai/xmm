# 🌟 全新重构的选项 18：既保留报错看日志能力，又死死掐住传统大日志上限
run_deep_log_clean() {
    echo -e "${yellow}=== 开始系统级日志深度清理与 Logrotate 轮转控容 ===${plain}"
    
    # 1. 强制清理包管理器缓存
    echo -e "${cyan}[+] 正在清理系统包管理器缓存...${plain}"
    if command -v apt-get >/dev/null 2>&1; then
        apt-get autoclean -y >/dev/null 2>&1 && apt-get clean -y >/dev/null 2>&1
    elif command -v yum >/dev/null 2>&1; then
        yum clean all >/dev/null 2>&1
    elif command -v apk >/dev/null 2>&1; then
        apk cache clean >/dev/null 2>&1
    fi

    # 2. 限制 systemd-journald 自身日志为 100M 上限
    if command -v journalctl >/dev/null 2>&1; then
        echo -e "${cyan}[+] 正在配置 /etc/systemd/journald.conf 限制内建日志上限为 100M...${plain}"
        if [ -f "/etc/systemd/journald.conf" ]; then
            sed -i 's/#SystemMaxUse=/SystemMaxUse=100M/g' /etc/systemd/journald.conf
            sed -i 's/SystemMaxUse=.*/SystemMaxUse=100M/g' /etc/systemd/journald.conf
            systemctl restart systemd-journald >/dev/null 2>&1
        fi
        echo -e "${cyan}[+] 正在裁剪当前内建历史日志...${plain}"
        journalctl --vacuum-size=50M >/dev/null 2>&1
    fi

    # 3. 🛡️ 核心黑科技：对传统的 syslog 和 daemon.log 注入高频硬轮转机制
    if [ -d "/etc/logrotate.d" ]; then
        echo -e "${cyan}[+] 正在为 syslog/daemon.log 注入 30M 强效硬控轮转规则...${plain}"
        cat << 'EOF' > /etc/logrotate.d/v2bx_anti_explode
/var/log/syslog
/var/log/daemon.log
/var/log/v2bx_err.log
/var/log/v2bx_out.log
{
    size 30M
    rotate 2
    missingok
    notifempty
    compress
    delaycompress
    sharedscripts
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate >/dev/null 2>&1 || systemctl restart rsyslog >/dev/null 2>&1 || kill -HUP `cat /var/run/syslogd.pid 2>/dev/null` >/dev/null 2>&1
    endscript
}
EOF
    fi

    # 4. 安全置空当前积压的冗余超大文件
    echo -e "${cyan}[+] 正在释放当前积压的冗余日志空间...${plain}"
    find /var/log -type f \( -name "*.log" -o -name "*.gz" -o -name "*.1" -o -name "*err" -o -name "*messages" \) 2>/dev/null | while read -r log_file; do
        true > "$log_file" 2>/dev/null
    done

    # 5. 清理临时文件与探针残存
    rm -rf /tmp/* /var/tmp/* 2>/dev/null
    if [ -d "/opt/nezha/agent" ]; then
        rm -f /opt/nezha/agent/systemd.* 2>/dev/null
    fi

    echo -e "${green}=== 配置成功！日志通道已开放，且增加了 [单文件最大 30M] 的自动熔断限制！===${plain}"
    df -h /
}

process_run() {
    local num; read -rp "请输入选择 [0-20]: " num
    case "$num" in
    0) nano /etc/V2bX/config.json && manage_service restart ;; 
    1|2) self_install_core ;; 
    3) 
        manage_service stop
        manage_service disable
        rm -rf /usr/local/V2bX /etc/V2bX /etc/systemd/system/V2bX.service /etc/init.d/V2bX /var/log/v2bx_err.log /etc/logrotate.d/v2bx_anti_explode
        if command -v systemctl &>/dev/null; then systemctl daemon-reload; fi
        echo "卸载完成" 
        ;;
    4) manage_service start ;; 
    5) manage_service stop ;; 
    6) manage_service restart ;; 
    7) manage_service status ;; 
    8) manage_service logs ;; 
    9) manage_service enable ;; 
    10) manage_service disable ;; 
    11) make_full_config ;; 
    12) make_advanced_modules ;; 
    13) /usr/local/V2bX/V2bX x25519 ;;
    14) update_shell ;; 
    15) install_bbr ;; 
    16) open_ports ;; 
    17) run_clean_script ;; 
    18) run_deep_log_clean ;;
    19) uptime && free -m && df -h ;; 
    20) exit 0 ;; 
    *) echo -e "${red}未知序号${plain}" ;;
    esac
}

while true; do show_menu; process_run; echo ""; read -rp "按回车键返回主菜单..." ; done
