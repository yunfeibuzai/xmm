self_install_core() {
    echo -e "${yellow}正在准备部署麦卖云后端核心组件...${plain}"
    
    # 交互式选择资源护卫限额策略
    echo -e "\n${cyan}====== 🛡️ 资源护卫限制策略选择 ======${plain}"
    echo -e "  ${green}1.${plain} 原生态无锁版 (满血狂飙，适合高配小鸡或大流量节点)"
    echo -e "  ${green}2.${plain} 标准防爆锁 (128M 内存锁 + 40% CPU 压制，推荐普通小鸡)"
    echo -e "  ${green}3.${plain} 极致低配锁 (40M 内存锁 + 20% CPU 压制，适合极限清贫的 NAT 鸡)"
    echo -e "  ${green}4.${plain} 自定义限额 (手动指定你想给的内存和 CPU 上限)"
    read -rp "请选择限额策略 [1-4] (默认 1): " limit_opt
    [[ -z "$limit_opt" ]] && limit_opt=1

    local mem_limit=""
    local cpu_limit=""
    
    if [ "$limit_opt" -eq 2 ]; then
        mem_limit=128
        cpu_limit=40
    elif [ "$limit_opt" -eq 3 ]; then
        mem_limit=40
        cpu_limit=20
    elif [ "$limit_opt" -eq 4 ]; then
        read -rp "请输入允许核心使用的内存硬性上限 (单位 MiB, 例如 256): " mem_limit
        read -rp "请输入允许核心使用的最大 CPU 使用率 (单位 %, 例如 60): " cpu_limit
        [[ -z "$mem_limit" ]] && mem_limit=128
        [[ -z "$cpu_limit" ]] && cpu_limit=40
    fi

    # 物理清除旧托管与僵尸进程
    manage_service stop
    manage_service disable
    killall -9 V2bX >/dev/null 2>&1
    mkdir -p /usr/local/V2bX /etc/V2bX
    rm -rf /usr/local/V2bX/V2bX /tmp/v2bx_tmp*

    local arch=$(uname -m)
    case "${arch}" in 
        x86_64 | amd64) arch="linux-64" ;; 
        arm64 | aarch64) arch="linux-arm64-v8a" ;; 
        *) arch="linux-64" ;; 
    esac
    
    local last_version=$(curl -sL "https://api.github.com/repos/wyx2685/V2bX/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
    [[ -z "$last_version" ]] && last_version="v0.4.0"

    local urls=(
        "https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
        "https://ghp.ci/https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
        "https://mirror.ghproxy.net/https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
    )

    local success=false
    for url in "${urls[@]}"; do
        echo -e "${yellow}探测拉取线: ${url}${plain}"
        local tmp_file="/tmp/v2bx_tmp_${RANDOM}.zip"
        
        wget -q --show-progress -O "$tmp_file" "$url" --timeout=15 

        if [[ -f "$tmp_file" && -s "$tmp_file" ]]; then
            if head -c 4 "$tmp_file" | grep -q 'PK'; then
                local tmp_dir="/tmp/v2bx_extract_${RANDOM}"
                mkdir -p "$tmp_dir"
                unzip -q -o "$tmp_file" -d "$tmp_dir"
                
                local b_target=""
                [[ -f "$tmp_dir/V2bX" ]] && b_target="$tmp_dir/V2bX"
                [[ -f "$tmp_dir/V2bX-${arch}" ]] && b_target="$tmp_dir/V2bX-${arch}"
                [[ -f "$tmp_dir/V2bX-linux-64" ]] && b_target="$tmp_dir/V2bX-linux-64"
                
                if [[ -n "$b_target" && -f "$b_target" ]]; then
                    mv -f "$b_target" /usr/local/V2bX/V2bX && success=true
                fi
                rm -rf "$tmp_dir"
            elif head -c 4 "$tmp_file" | grep -q 'ELF'; then
                mv -f "$tmp_file" /usr/local/V2bX/V2bX && success=true
            fi
        fi
        rm -f "$tmp_file"
        
        if [ "$success" = true ]; then
            chmod +x /usr/local/V2bX/V2bX
            echo -e "${green}[成功] 核心拉取成功！${plain}"
            break
        fi
    done

    if [ "$success" = false ]; then
        echo -e "${red}[错误] 所有拉取线路均失败，请检查服务器网络！${plain}"
        return
    fi

    rm -f /usr/local/V2bX/geoip.dat /usr/local/V2bX/geosite.dat

    if [ ! -f /etc/V2bX/config.json ]; then
        read -rp "未检测到配置文件，是否立即生成？(y/n) " ask_gen_config
        if [[ "$ask_gen_config" == "y" || "$ask_gen_config" == "Y" ]]; then
            make_full_config
        fi
    fi

    if command -v jq &>/dev/null && [ -f /etc/V2bX/config.json ]; then
        sed -i 's/"TCPFastOpen": true/"TCPFastOpen": false/g' /etc/V2bX/config.json 2>/dev/null
        sed -i 's/"SniffEnabled": true/"SniffEnabled": false/g' /etc/V2bX/config.json 2>/dev/null
    fi

    # 🌟 核心修改：维持全透明标准输出（确保可以查看报错），拒绝盲人运维
    if [ -d /etc/systemd/system ]; then
        cat << EOF > /etc/systemd/system/V2bX.service
[Unit]
Description=V2bX Service - Adaptive Managed
After=network.target

[Service]
ExecStart=/usr/local/V2bX/V2bX server -c /etc/V2bX/config.json
Restart=always
RestartSec=10
User=root
LimitNOFILE=65535
EOF

        if [ "$limit_opt" -ne 1 ]; then
            local high_mark=$((mem_limit * 8 / 10))
            cat << EOF >> /etc/systemd/system/V2bX.service
Environment="GOMEMLIMIT=${mem_limit}MiB"
Environment="GOGC=80"
CPUQuota=${cpu_limit}%
Nice=19
MemoryHigh=${high_mark}M
MemoryMax=${mem_limit}M
MemorySwapMax=0
OOMScoreAdjust=-100
EOF
        fi

        echo -e "[Install]\nWantedBy=multi-user.target" >> /etc/systemd/system/V2bX.service
        systemctl daemon-reload
        manage_service enable
        
    elif [ -d /etc/init.d ]; then
        cat << EOF > /etc/init.d/V2bX
#!/sbin/openrc-run
description="V2bX Alpine Service"
EOF

        if [ "$limit_opt" -ne 1 ]; then
            cat << EOF >> /etc/init.d/V2bX
export GOMEMLIMIT=${mem_limit}MiB
export GOGC=80
EOF
        fi

        cat << EOF >> /etc/init.d/V2bX
command="/usr/local/V2bX/V2bX"
command_args="server -c /etc/V2bX/config.json"
command_background=true
pidfile="/var/run/V2bX.pid"
output_log="/var/log/v2bx_out.log"
error_log="/var/log/v2bx_err.log"
EOF

        if [ "$limit_opt" -ne 1 ]; then
            echo 'start_stop_daemon_args="--nicelevel 19"' >> /etc/init.d/V2bX
        fi

        cat << EOF >> /etc/init.d/V2bX

depend() {
    need net
}
EOF
        chmod +x /etc/init.d/V2bX
        manage_service enable
    fi
    
    if [ -f /etc/V2bX/config.json ]; then
        manage_service restart
        echo -e "${green}V2bX 部署成功！日志处于全透明模式（可在主菜单选项 8 查看实时报错）。${plain}"
    else
        echo -e "${yellow}V2bX 已安装，请配置 config.json 后启动。${plain}"
    fi
}

