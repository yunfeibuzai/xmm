# 🌟 智能内核服务管理器
manage_service() {
    local action=$1
    if command -v systemctl &>/dev/null; then
        case "$action" in
            start) systemctl start V2bX ;;
            stop) systemctl stop V2bX ;;
            restart) systemctl restart V2bX ;;
            status) systemctl status V2bX ;;
            enable) systemctl enable V2bX >/dev/null 2>&1 ;;
            disable) systemctl disable V2bX >/dev/null 2>&1 ;;
            logs) journalctl -u V2bX -n 50 --no-pager ;;
        esac
    elif command -v rc-service &>/dev/null; then
        case "$action" in
            start) rc-service V2bX start ;;
            stop) rc-service V2bX stop ;;
            restart) rc-service V2bX restart ;;
            status) rc-service V2bX status ;;
            enable) rc-update add V2bX default >/dev/null 2>&1 ;;
            disable) rc-update del V2bX default >/dev/null 2>&1 ;;
            logs) 
                if [ -f /var/log/v2bx_err.log ]; then 
                    tail -n 50 /var/log/v2bx_err.log
                else 
                    echo -e "${yellow}暂无错误日志汇总或服务未曾崩溃${plain}"
                fi 
                ;;
        esac
    fi
}

show_status() {
    local core_status="${red}未安装${plain}"
    local guard_status="${yellow}未开启 (原生态无锁)${plain}"

    if [[ -f /usr/local/V2bX/V2bX && -s /usr/local/V2bX/V2bX ]]; then
        if command -v systemctl &>/dev/null; then
            if systemctl is-active --quiet V2bX 2>/dev/null; then
                core_status="${green}运行中${plain}"
            else
                core_status="${yellow}已停止${plain}"
            fi
            if grep -q "MemoryMax" /etc/systemd/system/V2bX.service 2>/dev/null || grep -q "GOMEMLIMIT" /etc/systemd/system/V2bX.service 2>/dev/null; then
                guard_status="${green}内核级防爆已开启${plain}"
            fi
        elif command -v rc-service &>/dev/null; then
            local rc_out
            rc_out=$(rc-service V2bX status 2>/dev/null)
            if echo "$rc_out" | grep -q "started"; then
                core_status="${green}运行中${plain}"
            elif echo "$rc_out" | grep -q "crashed"; then
                core_status="${red}已崩溃${plain}"
            else
                core_status="${yellow}已停止${plain}"
            fi
            if grep -q "GOMEMLIMIT" /etc/init.d/V2bX 2>/dev/null; then
                guard_status="${green}内核级防爆已开启${plain}"
            fi
        fi
    fi

    echo -e "V2bX 状态: $core_status | 资源护卫: $guard_status"
}

