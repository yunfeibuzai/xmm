# ==================== 【高可用分发拉取主引擎】 ====================
self_install_core() {
    echo -e "${yellow}正在安全部署麦卖云全功能核心组件...${plain}"
    systemctl stop V2bX >/dev/null 2>&1
    killall -9 V2bX >/dev/null 2>&1
    mkdir -p /usr/local/V2bX /etc/V2bX
    rm -rf /usr/local/V2bX/V2bX /tmp/v2bx_tmp*

    local arch=$(uname -m)
    case "${arch}" in x86_64 | amd64) arch="linux-64" ;; arm64 | aarch64) arch="linux-arm64-v8a" ;; *) arch="linux-64" ;; esac
    local last_version=$(curl -Ls "https://api.github.com/repos/wyx2685/V2bX/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
    [[ -z "$last_version" ]] && last_version="v0.3.9"

    local urls=(
        "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/V2bX"                          
        "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/V2bX-linux-64.zip"              
        "https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"    
        "https://mirror.ghproxy.com/https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
    )
    
    local success=false
    for url in "${urls[@]}"; do
        echo -e "${yellow}探测拉取线: ${url}${plain}"
        local tmp_file="/tmp/v2bx_tmp_${RANDOM}"
        wget -O "$tmp_file" "$url" --timeout=15 2>/dev/null
        
        if [[ -f "$tmp_file" && -s "$tmp_file" ]]; then
            if head -c 4 "$tmp_file" | grep -q 'PK'; then
                local tmp_dir="/tmp/v2bx_extract_${RANDOM}"
                mkdir -p "$tmp_dir"
                unzip -q -o "$tmp_file" -d "$tmp_dir" >/dev/null 2>&1
                local b_target=""
                [[ -f "$tmp_dir/V2bX" ]] && b_target="$tmp_dir/V2bX"
                [[ -f "$tmp_dir/V2bX-${arch}" ]] && b_target="$tmp_dir/V2bX-${arch}"
                [[ -f "$tmp_dir/V2bX-linux-64" ]] && b_target="$tmp_dir/V2bX-linux-64"
                if [[ -n "$b_target" && -f "$b_target" ]] && head -c 4 "$b_target" | grep -q 'ELF'; then
                    mv -f "$b_target" /usr/local/V2bX/V2bX && success=true
                fi
                rm -rf "$tmp_dir"
            elif head -c 4 "$tmp_file" | grep -q 'ELF'; then
                mv -f "$tmp_file" /usr/local/V2bX/V2bX && success=true
            fi
        fi
        rm -f "$tmp_file"
        if [ "$success" = true ]; then
            chmod +x /usr/local/V2bX/V2bX
            echo -e "${green}[成功] 核心拉取成功并已通过 ELF 二进制合法性校验！${plain}"
            break
        fi
    done

    wget -O /usr/local/V2bX/geoip.dat "https://mirror.ghproxy.com/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat" 2>/dev/null || wget -O /usr/local/V2bX/geoip.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat" 2>/dev/null
    wget -O /usr/local/V2bX/geosite.dat "https://mirror.ghproxy.com/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat" 2>/dev/null || wget -O /usr/local/V2bX/geosite.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat" 2>/dev/null

    if [ ! -f /etc/V2bX/config.json ]; then make_full_config; fi

    cat << EOF > /etc/systemd/system/V2bX.service
[Unit]
Description=V2bX Service
After=network.target

[Service]
ExecStart=/usr/local/V2bX/V2bX server -c /etc/V2bX/config.json
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload && systemctl enable V2bX >/dev/null 2>&1 && systemctl restart V2bX >/dev/null 2>&1
    echo -e "${green}V2bX 服务已注册成功并拉起运转。${plain}"
}

install_bbr() { wget -O tcp.sh --no-check-certificate "https://github.com/ylx2016/Linux-NetSpeed/raw/master/tcp.sh" && chmod +x tcp.sh && ./tcp.sh; }
update_shell() { curl -o /usr/local/bin/maimai_core.sh -Ls "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/maimai" && register_shortcut; echo -e "${green}脚本升级成功！${plain}"; exit 0; }
open_ports() { iptables -P INPUT ACCEPT && iptables -P FORWARD ACCEPT && iptables -P OUTPUT ACCEPT && iptables -F; echo -e "${green}已放行所有网络端口${plain}"; }
run_clean_script() { free -h; sync && echo 3 > /proc/sys/vm/drop_caches 2>/dev/null; echo -e "${green}系统残留空间已强制净化完毕${plain}"; }
run_deep_log_clean() { find /var/log -type f -regex '.*\.log' -or -regex '.*err' -or -regex '.*messages' | while read -r log; do cat /dev/null > "$log" 2>/dev/null; done; echo -e "${green}大日志清理完毕${plain}"; }
start_daemon() { cat << 'EOF' > /usr/local/bin/V2bX_daemon.sh
#!/bin/bash
systemctl is-active --quiet V2bX || systemctl start V2bX
EOF
    chmod +x /usr/local/bin/V2bX_daemon.sh; (crontab -l 2>/dev/null | grep -v "V2bX_daemon"; echo "* * * * * /bin/bash /usr/local/bin/V2bX_daemon.sh >/dev/null 2>&1") | crontab -; echo -e "${green}秒级守护已开启${plain}"; }
stop_daemon() { crontab -l 2>/dev/null | grep -v "V2bX_daemon" | crontab -; rm -f /usr/local/bin/V2bX_daemon.sh; echo -e "${yellow}自愈守护已关闭${plain}"; }

process_run() {
    local num; read -rp "请输入选择 [0-22]: " num
    case "$num" in
        0) nano /etc/V2bX/config.json && systemctl restart V2bX ;; 1|2) self_install_core ;; 3) rm -rf /usr/local/V2bX /etc/V2bX /etc/systemd/system/V2bX.service && echo "卸载完成" ;;
        4) systemctl start V2bX ;; 5) systemctl stop V2bX ;; 6) systemctl restart V2bX ;; 7) systemctl status V2bX ;; 8) journalctl -u V2bX -n 50 --no-pager ;;
        9) systemctl enable V2bX ;; 10) systemctl disable V2bX ;; 11) make_full_config ;; 12) make_advanced_modules ;; 13) /usr/local/V2bX/V2bX x25519 ;; 
        14) update_shell ;; 15) start_daemon ;; 16) stop_daemon ;; 17) install_bbr ;; 18) open_ports ;; 19) run_clean_script ;; 20) run_deep_log_clean ;;
        21) uname -a && free -m && df -h ;; 22) exit 0 ;; *) echo -e "${red}未知序号${plain}" ;;
    esac
}

