}

check_status() {
    if [[ ! -f /usr/local/V2bX/V2bX ]]; then return 2; fi
    if [[ x"${release}" == x"alpine" ]]; then
        service V2bX status 2>&1 | grep -Eqi "started|running" || [ -f /run/V2bX.pid ] && return 0 || return 1
    else
        systemctl is-active --quiet V2bX && return 0 || return 1
    fi
}

start_V2bX() {
    check_status
    if [[ $? == 0 ]]; then echo -e "${green}V2bX 已在运行中，无需重复启动${plain}"; return; fi
    if [[ x"${release}" == x"alpine" ]]; then service V2bX start >/dev/null 2>&1; else systemctl start V2bX >/dev/null 2>&1; fi
    sleep 1 && check_status
    [[ $? == 0 ]] && echo -e "${green}V2bX 启动成功${plain}" || echo -e "${red}V2bX 启动失败，请检查日志${plain}"
}

stop_V2bX() {
    if [[ x"${release}" == x"alpine" ]]; then service V2bX stop >/dev/null 2>&1; else systemctl stop V2bX >/dev/null 2>&1; fi
    pidof V2bX | xargs kill -9 >/dev/null 2>&1
    echo -e "${green}V2bX 已彻底停止并释放残余内存${plain}"
}

restart_V2bX() {
    stop_V2bX && sleep 1 && start_V2bX
}

enable_V2bX() {
    if [[ x"${release}" == x"alpine" ]]; then rc-update add V2bX default >/dev/null 2>&1; else systemctl enable V2bX >/dev/null 2>&1; fi
    echo -e "${green}已设置 V2bX 开机自启${plain}"
}

disable_V2bX() {
    if [[ x"${release}" == x"alpine" ]]; then rc-update del V2bX default >/dev/null 2>&1; else systemctl disable V2bX >/dev/null 2>&1; fi
    echo -e "${green}已取消 V2bX 开机自启${plain}"
}

view_log() {
    if [[ x"${release}" == x"alpine" ]]; then
        tail -n 50 /var/log/messages 2>/dev/null | grep V2bX || echo "暂无可用日志"
    else
        journalctl -u V2bX -n 50 --no-pager
    fi
}

edit_config() {
    if command -v nano &>/dev/null; then
        nano /etc/V2bX/config.json
    elif command -v vi &>/dev/null; then
        vi /etc/V2bX/config.json
    else
        echo -e "${red}未检测到文本编辑器，请手动修改 /etc/V2bX/config.json${plain}"
    fi
}

make_config() {
    echo -e "\n${yellow}========== 智能节点配置向导 (手机友好交互) ==========${plain}"
    mkdir -p /etc/V2bX
    
    read -rp "1. 请输入机场前端对接地址 (ApiHost，例如 https://maimai.cloud): " api_host
    read -rp "2. 请输入机场前端通讯密钥 (ApiKey/Token): " api_key
    read -rp "3. 请输入该节点在机场的真实ID (NodeID): " node_id
    
    echo -e "4. 请选择对应的节点协议类型 (NodeType):"
    echo -e " [1] Vless (默认)\n [2] Trojan\n [3] Shadowsocks\n [4] Hysteria2"
    read -rp "请输入数字 [1-4] 选择协议: " type_num
    case "$type_num" in
        2) node_type="Trojan" ;;
        3) node_type="Shadowsocks" ;;
        4) node_type="Hysteria2" ;;
        *) node_type="Vless" ;;
    esac

    echo -e "5. 请选择底层执行核心 (Core):"
    echo -e " [1] sing (强力推荐)\n [2] xray"
    read -rp "请输入数字 [1-2] (默认1): " core_num
    [[ "$core_num" == "2" ]] && core_type="xray" || core_type="sing"

    cat << EOF > /etc/V2bX/config.json
{
  "Log": {
    "Level": "info",
    "Output": ""
  },
  "Cores": [
    {
      "Type": "${core_type}",
      "Log": {
        "Level": "info",
        "Timestamp": true
      }
    }
  ],
  "Nodes": [
    {
      "Core": "${core_type}",
      "ApiHost": "${api_host}",
      "ApiKey": "${api_key}",
      "NodeID": ${node_id},
      "NodeType": "${node_type}",
      "Timeout": 30,
      "ListenIP": "0.0.0.0",
      "SendIP": "0.0.0.0",
      "SniffEnabled": true
    }
  ]
}
EOF
    echo -e "${green}[成功] 专属节点配置文件已成功写入到 /etc/V2bX/config.json！${plain}"
}

self_install_core() {
    echo -e "${yellow}正在安全部署麦卖云原生全功能核心组件...${plain}"
    mkdir -p /usr/local/V2bX /etc/V2bX
    
    # 🌟 修复0字节Bug：直接拉取 wyx2685 编译完成的完整多内核全协议主二进制程序
    echo -e "${yellow}正在拉取全协议高可用主可执行核心...${plain}"
    local arch=$(uname -m)
    if [[ "${arch}" == "x86_64" ]]; then
        wget -N -O /usr/local/V2bX/V2bX "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/V2bX-linux-amd64"
    elif [[ "${arch}" == "aarch64" ]]; then
        wget -N -O /usr/local/V2bX/V2bX "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/V2bX-linux-arm64"
    else
        # 兼容备用源
        wget -N -O /usr/local/V2bX/V2bX "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/V2bX"
    fi
    chmod +x /usr/local/V2bX/V2bX
    
    # 同步获取官方完整的路由规则包，彻底干掉0字节
    echo -e "${yellow}正在从 wyx2685 官方实时同步获取最新 geoip 和 geosite 路由包...${plain}"
    wget -N -O /usr/local/V2bX/geoip.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat"
    wget -N -O /usr/local/V2bX/geosite.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat"
    
    # 配置文件判断逻辑
    if [ ! -f /etc/V2bX/config.json ]; then
        make_config
    else
        read -rp "检测到本地已有原节点配置，是否需要重新输入参数覆盖重写？(y/n, 默认n): " remk
        if [[ "$remk" == "y" || "$remk" == "Y" ]]; then
            make_config
        fi
    fi

    # 自动注册并渲染开机守护程序
    if [[ x"${release}" != x"alpine" ]]; then
        cat << EOF > /etc/systemd/system/V2bX.service
[Unit]
Description=V2bX Service
After=network.target

[Service]
ExecStart=/usr/local/V2bX/V2bX -c /etc/V2bX/config.json
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF
        systemctl daemon-reload
        systemctl enable V2bX
        systemctl restart V2bX
    fi
    echo -e "${green}V2bX 核心部署与配置文件处理圆满完成！已自动为您启动服务。${plain}"
}

install_bbr() {
    rm -f tcp.sh tcp.sh.* bbr.sh bbr.sh.*
    wget -O tcp.sh --no-check-certificate "https://github.com/ylx2016/Linux-NetSpeed/raw/master/tcp.sh"
    if [ -f tcp.sh ]; then chmod +x tcp.sh && clear && ./tcp.sh; fi
}

update_shell() {
    echo -e "${yellow}正在从您的专属仓库同步最新管理脚本...${plain}"
    curl -o "$filepath" -Ls "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/maimai" && chmod +x "$filepath"
    register_shortcut
    echo -e "${green}管理脚本升级成功，请重新运行脚本！${plain}"
    exit 0
}

open_ports() {
    if command -v iptables &>/dev/null; then
        iptables -P INPUT ACCEPT && iptables -P FORWARD ACCEPT && iptables -P OUTPUT ACCEPT && iptables -F
        echo -e "${green}已成功放行 VPS 的所有网络端口 (iptables)${plain}"
    fi
}

run_clean_script() {
    echo -e "\n\033[1;33m========== 物理内存总体概况 ==========\033[0m"
    free -h
    echo -e "\n\033[1;35m========== 挂机/带宽共享容器检测与强杀 ==========\033[0m"
    if command -v docker >/dev/null 2>&1; then
        bad_containers=$(docker ps -a --format "{{.ID}}\t{{.Names}}" 2>/dev/null | grep -E "pawns|honeygain|repocket|tm|traffmonetizer")
        if [ -n "$bad_containers" ]; then
            echo "$bad_containers" | while read -r line; do
                cid=$(echo "$line" | awk '{print $1}')
                docker rm -f "$cid" >/dev/null 2>&1
            done
            docker volume prune -f >/dev/null 2>&1
        fi
    fi
    sync && echo 3 > /proc/sys/vm/drop_caches 2>/dev/null
    free -h
}

run_network_test() {
    clear
    echo -e "${yellow}========== 麦卖云小鸡网络丢包与延迟测试 ==========${plain}"
    echo -n "1. 连接到你的 GitHub 仓库速度: "
    res1=$(curl -o /dev/null -s -w '%{time_total}' --connect-timeout 4 "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/maimai")
    echo -e "${green}${res1} 秒${plain}"
}

run_deep_log_clean() {
    find /var/log -type f -regex '.*\.log' -or -regex '.*err' -or -regex '.*messages' 2>/dev/null | while read -r logfile; do
        cat /dev/null > "$logfile" 2>/dev/null
    done
    sync && echo 3 > /proc/sys/vm/drop_caches 2>/dev/null
    echo -e "${green}[成功] 空间大爆破完成！${plain}"
}

start_daemon() {
    cat << 'EOF' > /usr/local/bin/V2bX_daemon.sh
#!/bin/bash
if [ -f /usr/local/V2bX/V2bX ]; then
    if cat /proc/version 2>/dev/null | grep -Eqi "alpine"; then
        service V2bX status 2>&1 | grep -Eqi "started|running" || [ -f /run/V2bX.pid ] || service V2bX start
    else
        systemctl is-active --quiet V2bX || systemctl start V2bX
    fi
fi
EOF
    chmod +x /usr/local/bin/V2bX_daemon.sh
    (crontab -l 2>/dev/null | grep -v "V2bX_daemon"; echo "* * * * * /bin/bash /usr/local/bin/V2bX_daemon.sh >/dev/null 2>&1") | crontab -
    echo -e "${green}自动化智能自愈守护开启成功！${plain}"
}

stop_daemon() {
    crontab -l 2>/dev/null | grep -v "V2bX_daemon" | crontab -
    rm -f /usr/local/bin/V2bX_daemon.sh
    echo -e "${yellow}自动化智能自愈守护已完全关闭。${plain}"
}

view_vps_info() {
    clear
    echo -e "${cyan}========== 麦卖云小鸡硬件环境全能看板 ==========${plain}"
    echo -n "系统内核: " && uname -r
    echo -n "系统总负载: " && awk '{print $1,$2,$3}' /proc/loadavg
}

process_run() {
    local num
    read -rp "请输入选择 [0-23]: " num
    case "$num" in
        0) edit_config ;;
        1|2) self_install_core ;; 
        3) rm -rf /usr/local/V2bX /etc/V2bX /usr/bin/V2bX /usr/bin/v2bx && echo "已完全卸载" ;;
        4) start_V2bX ;;
        5) stop_V2bX ;;
        6) restart_V2bX ;;
        7) check_status && echo -e "状态: ${green}正在运行${plain}" || echo -e "状态: ${red}未运行${plain}" ;;
        8) view_log ;;
        9) enable_V2bX ;;
        10) disable_V2bX ;;
        11) install_bbr ;;
        12) /usr/local/V2bX/V2bX version 2>/dev/null || echo -e "${green}原生高可用内核${plain}" ;;
        13) /usr/local/V2bX/V2bX x25519 ;;
        14) update_shell ;;
        15) make_config ;;
        16) run_clean_script ;;
        17) open_ports ;;
        18) exit 0 ;;
        19) run_network_test ;;
        20) run_deep_log_clean ;;
        21) start_daemon ;;
        22) stop_daemon ;;
        23) view_vps_info ;;
        *) echo -e "${red}请输入正确的数字 [0-23]${plain}" ;;
    esac
}

if [[ $# -gt 0 ]]; then
    case "$1" in
        "start") start_V2bX ;; "stop") stop_V2bX ;; "restart") restart_V2bX ;;
        "status") check_status && echo -e "状态: ${green}正在运行${plain}" || echo -e "状态: ${red}未运行${plain}" ;;
        "update"|"install") self_install_core ;;
        *) show_menu; process_run ;;
    esac
else
    while true; do
        show_menu; process_run; echo ""; read -rp "按回车键返回主菜单..."
    done
fi
