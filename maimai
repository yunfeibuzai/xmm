        core_status="${red}未安装或核心损坏${plain}"
    else
        if systemctl is-active --quiet V2bX 2>/dev/null; then
            core_status="${green}开${plain}"
        else
            core_status="${yellow}未启动${plain}"
        fi
    fi

    if ps aux | grep -v grep | grep -q "V2bX_daemon.sh"; then
        daemon_status="${green}已开启(安全低耗版)${plain}"
    else
        daemon_status="${red}未运行${plain}"
    fi

    echo -e "V2bX 状态: $core_status | 自愈守护: $daemon_status"
}

