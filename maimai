make_full_config() {
    echo -e "\n${yellow}========== 精确对齐向导式配置创建逻辑 ==========${plain}"
    mkdir -p /etc/V2bX
    
    local saved_file="/etc/V2bX/.saved_creds"
    local default_host="https://example.com"
    local default_key=""
    
    if [[ -f "$saved_file" ]]; then
        source "$saved_file" 2>/dev/null
        default_host=${saved_host:-"https://example.com"}
        default_key=${saved_key:-""}
    fi

    local api_host="" api_key="" core_num="" core_type="" node_id="" protocol_num="" node_type=""
    local reality_yn="n" tls_yn="n" cert_mode_num="" cert_mode="none" cert_domain="" cf_token=""

    read -rp "请 输 入 机 场 网 址 (如 ${default_host})： " input_host
    api_host=${input_host:-"$default_host"}
    
    if [[ -n "$default_key" ]]; then
        read -rp "请 输 入 面 板 对 接 API Key (直接回车使用已保存的Key): " input_key
        api_key=${input_key:-"$default_key"}
    else
        while [[ -z "$api_key" ]]; do
            read -rp "请 输 入 面 板 对 接 API Key： " api_key
        done
    fi

    read -rp "是 否 设 置 固 定 的 机 场 网 址 和 API Key？ (y/n) " save_yn
    if [[ "$save_yn" == "y" || "$save_yn" == "Y" ]]; then
        echo "saved_host=\"$api_host\"" > "$saved_file"
        echo "saved_key=\"$api_key\"" >> "$saved_file"
        echo -e "${green}[提示] 凭证已固定锁定。${plain}"
    fi

    echo -e "请 选 择 节 点 核 心 类 型 ："
    echo -e "1. xray"
    echo -e "2. singbox"
    echo -e "3. hysteria2"
    while [[ ! "$core_num" =~ ^[1-3]$ ]]; do
        read -rp "请 输 入 ： " core_num
    done
    case "$core_num" in 1) core_type="xray" ;; 2) core_type="sing" ;; 3) core_type="hysteria2" ;; esac

    while [[ -z "$node_id" ]]; do
        read -rp "请 输 入 节 点 Node ID： " node_id
    done

    echo -e "请 选 择 节 点 传 输 协 议 ："
    echo -e "1. Shadowsocks"
    echo -e "2. Vless"
    echo -e "3. Vmess"
    echo -e "4. Hysteria"
    echo -e "5. Hysteria2"
    echo -e "6. Trojan"
    echo -e "7. Tuic"
    echo -e "8. AnyTLS"
    while [[ ! "$protocol_num" =~ ^[1-8]$ ]]; do
        read -rp "请 输 入 ： " protocol_num
    done

    case "$protocol_num" in
        1) node_type="shadowsocks" ;; 2) node_type="vless" ;; 3) node_type="vmess" ;; 4) node_type="hysteria" ;;
        5) node_type="hysteria2" ;; 6) node_type="trojan" ;; 7) node_type="tuic" ;; 8) node_type="anytls" ;;
    esac

    local run_tls_flow=false
    if [[ "$protocol_num" == "1" || "$protocol_num" == "3" || "$protocol_num" == "6" || "$protocol_num" == "8" ]]; then
        read -rp "请 选 择 是 否 进 行 TLS配 置 ？ (y/n)" tls_yn
        [[ "$tls_yn" == "y" || "$tls_yn" == "Y" ]] && run_tls_flow=true
    elif [[ "$protocol_num" == "2" ]]; then
        read -rp "请 选 择 是 否 为 reality节 点 ？ (y/n)" reality_yn
        if [[ "$reality_yn" == "y" || "$reality_yn" == "Y" ]]; then
            cert_mode="none"
        else
            read -rp "请 选 择 是 否 进 行 TLS配 置 ？ (y/n)" tls_yn
            [[ "$tls_yn" == "y" || "$tls_yn" == "Y" ]] && run_tls_flow=true
        fi
    elif [[ "$protocol_num" == "4" || "$protocol_num" == "5" || "$protocol_num" == "7" ]]; then
        run_tls_flow=true
    fi

    if [ "$run_tls_flow" = true ]; then
        echo -e "请 选 择 证 书 申 请 模 式 ："
        echo -e "1. http模 式 自 动 申 请 ， 节 点 域 名 已 正 确 解 析"
        echo -e "2. dns模 式 自 动 申 请 ， 需 填 入 正 确 域 名 服 务商 API参 数"
        echo -e "3. self模 式 ， 自 签 证 书 或 提 供 已 有 证 书 文 件"
        while [[ ! "$cert_mode_num" =~ ^[1-3]$ ]]; do
            read -rp "请 输 入 ： " cert_mode_num
        done

        if [[ "$cert_mode_num" == "1" || "$cert_mode_num" == "2" ]]; then
            while [[ -z "$cert_domain" ]]; do
                read -rp "请输入证书申请域名 (如 domain.com): " cert_domain
            done
            if [[ "$cert_mode_num" == "1" ]]; then
                cert_mode="http"
            else
                cert_mode="dns"
                while [[ -z "$cf_token" ]]; do
                    read -rp "CLOUDFLARE_DNS_API_TOKEN: 请 输入 你的 真实 CF_Token_ 粘贴 在 这里: " cf_token
                done
            fi
        elif [[ "$cert_mode_num" == "3" ]]; then
            cert_mode="self"
        fi
    fi

    local cert_block=""
    if [[ "$cert_mode" == "dns" ]]; then
        cert_block='{ "CertMode": "dns", "RejectUnknownSni": false, "CertDomain": "'"${cert_domain}"'", "CertFile": "/etc/V2bX/server.crt.cer", "KeyFile": "/etc/V2bX/cert.key", "Email": "v2bx@github.com", "Provider": "cloudflare", "DNSEnv": { "CLOUDFLARE_DNS_API_TOKEN": "'"${cf_token}"'" } }'
    elif [[ "$cert_mode" == "http" ]]; then
        cert_block='{ "CertMode": "http", "RejectUnknownSni": false, "CertDomain": "'"${cert_domain}"'", "CertFile": "/etc/V2bX/server.crt.cer", "KeyFile": "/etc/V2bX/cert.key", "Email": "v2bx@github.com" }'
    elif [[ "$cert_mode" == "self" ]]; then
        cert_block='{ "CertMode": "self", "RejectUnknownSni": false, "CertDomain": "cf.babymonster.cc.cd", "CertFile": "/etc/V2bX/server.crt.cer", "KeyFile": "/etc/V2bX/cert.key", "Email": "v2bx@github.com" }'
    else
        cert_block='{ "CertMode": "none" }'
    fi

    if [[ ! -f /etc/V2bX/sing_origin.json ]]; then
        cat << 'EOF' > /etc/V2bX/sing_origin.json
{ "outbounds": [ { "type": "direct", "tag": "direct" } ] }
EOF
    fi

    cat << EOF > /etc/V2bX/config.json
{
    "Log": { "Level": "none", "Output": "" },
    "Cores": [{
        "Type": "${core_type}",
        "Log": { "Level": "error", "Timestamp": true },
        "NTP": { "Enable": false, "Server": "time.apple.com", "ServerPort": 0 },
        "OriginalPath": "/etc/V2bX/sing_origin.json"
    }],
    "Nodes": [{
            "Core": "${core_type}", "ApiHost": "${api_host}", "ApiKey": "${api_key}", "NodeID": ${node_id}, "NodeType": "${node_type}",
            "Timeout": 30, "ListenIP": "::", "SendIP": "0.0.0.0", "Port": 20026, "DeviceOnlineMinTraffic": 200, "MinReportTraffic": 0,
            "TCPFastOpen": true, "SniffEnabled": true, "CertConfig": ${cert_block}
        }]
}
EOF
    echo -e "${green}[成功] 1:1 净版模板已精准写入 /etc/V2bX/config.json${plain}"
}

self_install_core() {
    echo -e "${yellow}正在安全部署麦卖云全功能核心组件...${plain}"
    systemctl stop V2bX >/dev/null 2>&1
    killall -9 V2bX >/dev/null 2>&1
    mkdir -p /usr/local/V2bX /etc/V2bX
    rm -rf /usr/local/V2bX/V2bX /tmp/v2bx_tmp*

    local arch=$(uname -m)
    case "${arch}" in x86_64 | amd64) arch="linux-64" ;; arm64 | aarch64) arch="linux-arm64-v8a" ;; *) arch="linux-64" ;; esac
    local last_version=$(curl -Ls "https://api.github.com/repos/wyx2685/V2bX/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
    [[ -z "$last_version" ]] && last_version="v0.3.9"

    local urls=(
        "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/V2bX"                          
        "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/V2bX-linux-64.zip"              
        "https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"    
        "https://mirror.ghproxy.com/https://github.com/wyx2685/V2bX/releases/download/${last_version}/V2bX-${arch}.zip"
    )
    
    local success=false
    for url in "${urls[@]}"; do
        echo -e "${yellow}探测拉取线: ${url}${plain}"
        local tmp_file="/tmp/v2bx_tmp_${RANDOM}"
        wget -O "$tmp_file" "$url" --timeout=15 2>/dev/null
        
        if [[ -f "$tmp_file" && -s "$tmp_file" ]]; then
            if head -c 4 "$tmp_file" | grep -q 'PK'; then
                local tmp_dir="/tmp/v2bx_extract_${RANDOM}"
                mkdir -p "$tmp_dir"
                unzip -q -o "$tmp_file" -d "$tmp_dir" >/dev/null 2>&1
                local b_target=""
                [[ -f "$tmp_dir/V2bX" ]] && b_target="$tmp_dir/V2bX"
                [[ -f "$tmp_dir/V2bX-${arch}" ]] && b_target="$tmp_dir/V2bX-${arch}"
                [[ -f "$tmp_dir/V2bX-linux-64" ]] && b_target="$tmp_dir/V2bX-linux-64"
                if [[ -n "$b_target" && -f "$b_target" ]] && head -c 4 "$b_target" | grep -q 'ELF'; then
                    mv -f "$b_target" /usr/local/V2bX/V2bX && success=true
                fi
                rm -rf "$tmp_dir"
            elif head -c 4 "$tmp_file" | grep -q 'ELF'; then
                mv -f "$tmp_file" /usr/local/V2bX/V2bX && success=true
            fi
        fi
        rm -f "$tmp_file"
        if [ "$success" = true ]; then
            chmod +x /usr/local/V2bX/V2bX
            echo -e "${green}[成功] 核心拉取成功并已通过 ELF 二进制合法性校验！${plain}"
            break
        fi
    done

    wget -O /usr/local/V2bX/geoip.dat "https://mirror.ghproxy.com/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat" 2>/dev/null || wget -O /usr/local/V2bX/geoip.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geoip.dat" 2>/dev/null
    wget -O /usr/local/V2bX/geosite.dat "https://mirror.ghproxy.com/https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat" 2>/dev/null || wget -O /usr/local/V2bX/geosite.dat "https://raw.githubusercontent.com/wyx2685/V2bX-script/master/geosite.dat" 2>/dev/null

    if [ ! -f /etc/V2bX/config.json ]; then
        read -rp "是否生成配置文件？(y/n)" ask_gen_config
        if [[ "$ask_gen_config" == "y" || "$ask_gen_config" == "Y" ]]; then
            make_full_config
        else
            echo -e "${yellow}[提示] 跳过配置文件自动生成，请后续通过功能 11 手动创建。${plain}"
        fi
    fi

    cat << EOF > /etc/systemd/system/V2bX.service
[Unit]
Description=V2bX Service
After=network.target

[Service]
ExecStart=/usr/local/V2bX/V2bX server -c /etc/V2bX/config.json
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload && systemctl enable V2bX >/dev/null 2>&1 && systemctl reset-failed V2bX >/dev/null 2>&1 && systemctl restart V2bX >/dev/null 2>&1
    echo -e "${green}V2bX 服务已注册成功并拉起运转。${plain}"
}

make_advanced_modules() {
    echo -e "\n${yellow}========== 进阶：高级外部功能矩阵配置生成器 ==========${plain}"
    echo -e " [1] 生成 Sing-box 自定义策略路由组件 (sing_origin.json)"
    echo -e " [2] 生成 Xray 自定义高级 DNS 解锁组件 (dns.json)"
    echo -e " [3] 生成 Xray 强审计自定义拦截路由组件 (route.json)"
    echo -e " [4] 生成 Xray 多端本地入站与自由出口拦截器"
    read -rp "请做出你的选择 [1-4]: " am_num
    case "$am_num" in
        1)
            cat << 'EOF' > /etc/V2bX/sing_origin.json
{
  "dns": { "servers": [ { "tag": "cloudflare", "address": "1.1.1.1", "strategy": "prefer_ipv4" } ] },
  "outbounds": [ { "tag": "direct", "type": "direct", "domain_strategy": "prefer_ipv4" } ],
  "route": { "rules": [ { "ip_is_private": true, "action": "reject" }, { "rule_set": [ "geosite-category-ads-all" ], "action": "reject" } ] }
}
EOF
            echo -e "${green}[成功] /etc/V2bX/sing_origin.json 生成完毕！${plain}"
            ;;
        2)
            cat << 'EOF' > /etc/V2bX/dns.json
{ "servers": [ "8.8.8.8", { "address": "1.1.2.2", "port": 53, "domains": [ "geosite:netflix" ] } ] }
EOF
            echo -e "${green}[成功] /etc/V2bX/dns.json 优先解锁模板组装完毕！${plain}"
            ;;
        3)
            cat << 'EOF' > /etc/V2bX/route.json
{ "domainStrategy": "IPOnDemand", "rules": [ { "type": "field", "outboundTag": "block", "ip": [ "geoip:private" ] }, { "type": "field", "outboundTag": "block", "protocol": [ "bittorrent" ] } ] }
EOF
            echo -e "${green}[成功] /etc/V2bX/route.json 防BT审计策略阻断落盘！${plain}"
            ;;
        4)
            cat << 'EOF' > /etc/V2bX/custom_inbound.json
[ { "listen": "0.0.0.0", "port": 1234, "protocol": "socks", "settings": { "auth": "noauth", "udp": false } } ]
EOF
            cat << 'EOF' > /etc/V2bX/custom_outbound.json
[ { "tag": "IPv4_out", "protocol": "freedom" }, { "protocol": "blackhole", "tag": "block" } ]
EOF
            echo -e "${green}[成功] 入站与黑洞出口拦截器同步挂载完成！${plain}"
            ;;
    esac
}

install_bbr() { wget -O tcp.sh --no-check-certificate "https://github.com/ylx2016/Linux-NetSpeed/raw/master/tcp.sh" && chmod +x tcp.sh && ./tcp.sh; }
update_shell() { curl -o /usr/local/bin/maimai_core.sh -Ls "https://raw.githubusercontent.com/yunfeibuzai/xmm/main/maimai" && register_shortcut; echo -e "${green}脚本升级成功！${plain}"; exit 0; }
open_ports() { iptables -P INPUT ACCEPT && iptables -P FORWARD ACCEPT && iptables -P OUTPUT ACCEPT && iptables -F; echo -e "${green}已放行所有网络端口${plain}"; }
run_clean_script() { free -h; sync && echo 3 > /proc/sys/vm/drop_caches 2>/dev/null; echo -e "${green}系统残留空间已强制净化完毕${plain}"; }
run_deep_log_clean() { find /var/log -type f -regex '.*\.log' -or -regex '.*err' -or -regex '.*messages' | while read -r log; do cat /dev/null > "$log" 2>/dev/null; done; echo -e "${green}大日志清理完毕${plain}"; }
start_daemon() { cat << 'EOF' > /usr/local/bin/V2bX_daemon.sh
#!/bin/bash
systemctl is-active --quiet V2bX || (systemctl daemon-reload && systemctl start V2bX)
EOF
    chmod +x /usr/local/bin/V2bX_daemon.sh; (crontab -l 2>/dev/null | grep -v "V2bX_daemon"; echo "* * * * * /bin/bash /usr/local/bin/V2bX_daemon.sh >/dev/null 2>&1") | crontab -; echo -e "${green}秒级守护已开启${plain}"; }
stop_daemon() { crontab -l 2>/dev/null | grep -v "V2bX_daemon" | crontab -; rm -f /usr/local/bin/V2bX_daemon.sh; echo -e "${yellow}自愈守护已关闭${plain}"; }

process_run() {
    local num; read -rp "请输入选择 [0-22]: " num
    case "$num" in
        0) nano /etc/V2bX/config.json && systemctl daemon-reload && systemctl restart V2bX ;; 1|2) self_install_core ;; 3) rm -rf /usr/local/V2bX /etc/V2bX /etc/systemd/system/V2bX.service && echo "卸载完成" ;;
        4) systemctl daemon-reload && systemctl start V2bX ;; 5) systemctl stop V2bX ;; 6) systemctl daemon-reload && systemctl reset-failed V2bX && systemctl restart V2bX ;; 7) systemctl status V2bX ;; 8) journalctl -u V2bX -n 50 --no-pager ;;
        9) systemctl enable V2bX ;; 10) systemctl disable V2bX ;; 11) make_full_config ;; 12) make_advanced_modules ;; 13) /usr/local/V2bX/V2bX x25519 ;; 
        14) update_shell ;; 15) start_daemon ;; 16) stop_daemon ;; 17) install_bbr ;; 18) open_ports ;; 19) run_clean_script ;; 20) run_deep_log_clean ;;
        21) uname -a && free -m && df -h ;; 22) exit 0 ;; *) echo -e "${red}未知序号${plain}" ;;
    esac
}

while true; do show_menu; process_run; echo ""; read -rp "按回车键返回主菜单..." ; done
