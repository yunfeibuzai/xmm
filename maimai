#!/bin/bash

# 麦卖云 V2bX 后端全能王牌脚本 (系统深度净化版)
sh_ver="3.7.8"

red='\033[31m'; green='\033[32m'; yellow='\033[33m'
magenta='\033[35m'; cyan='\033[36m'; plain='\033[0m'

[[ $EUID -ne 0 ]] && echo -e "${red}错误：${plain}必须使用root用户运行此脚本！\n" && exit 1

# 基础依赖自动补齐
for cmd in wget curl tar unzip jq nano; do
    if ! command -v $cmd &>/dev/null; then
        apt-get update && apt-get install -y $cmd || yum install -y $cmd || apk add --no-cache $cmd
    fi
done

# 快捷命令注册
register_shortcut() {
    mkdir -p /usr/local/bin
    if [[ "$0" != "/usr/local/bin/maimai_core.sh" && -f "$0" ]]; then
        cp -f "$0" /usr/local/bin/maimai_core.sh
        chmod +x /usr/local/bin/maimai_core.sh
    fi
    rm -f /usr/bin/maimai /usr/bin/v2bx
    if [[ -f /usr/local/bin/maimai_core.sh ]]; then
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/maimai
        ln -sf /usr/local/bin/maimai_core.sh /usr/bin/v2bx
        chmod +x /usr/bin/maimai /usr/bin/v2bx
    fi
}
register_shortcut

# 状态看板颜色保持
show_status() {
    if [[ ! -f /usr/local/V2bX/V2bX ]] || [[ ! -s /usr/local/V2bX/V2bX ]]; then
        echo -e "V2bX 状态: ${red}未安装或核心损坏${plain}"
        return
    fi
    systemctl is-active --quiet V2bX 2>/dev/null && echo -e "V2bX 状态: ${green}开${plain}" || echo -e "V2bX 状态: ${yellow}未启动${plain}"
    crontab -l 2>/dev/null | grep -q "V2bX_daemon" && echo -e "自动化守护: ${green}开${plain}" || echo -e "自动化守护: ${red}关${plain}"
}

