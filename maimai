    if [ $? -eq 0 ]; then echo -e "${green}${res2} 秒${plain}"; else echo -e "${red}连接受限/超时${plain}"; fi
    echo -n "3. 联通到 Cloudflare CDN 边缘网关: "
    res3=$(curl -o /dev/null -s -w '%{time_total}' --connect-timeout 3 "https://1.1.1.1")
    if [ $? -eq 0 ]; then echo -e "${green}${res3} 秒${plain}"; else echo -e "${red}丢包严重${plain}"; fi
    echo -n "4. 联通到 Google 核心基础设施网络: "
    res4=$(curl -o /dev/null -s -w '%{time_total}' --connect-timeout 3 "https://www.google.com")
    if [ $? -eq 0 ]; then echo -e "${green}${res4} 秒${plain}"; else echo -e "${red}阻断不可达${plain}"; fi
    echo -e "${yellow}==================================================${plain}"
}
run_deep_log_clean() {
    clear
    echo -e "${red}========== 强制爆破系统死锁大日志与垃圾缓存 ==========${plain}"
    find /var/log -type f -regex '.*\.log' -or -regex '.*err' -or -regex '.*messages' 2>/dev/null | while read -r logfile; do
        size=$(du -h "$logfile" 2>/dev/null | awk '{print $1}')
        cat /dev/null > "$logfile" 2>/dev/null && echo "已爆破释放系统日志: $logfile ($size)"
    done
    if [ "$release" != "alpine" ] && command -v journalctl &>/dev/null; then
        journalctl --vacuum-size=10M >/dev/null 2>&1
    fi
    sync && echo 3 > /proc/sys/vm/drop_caches 2>/dev/null
    echo -e "${green}[成功] 空间大爆破完成！${plain}"
}

start_daemon() {
    cat << 'EOF' > /usr/local/bin/V2bX_daemon.sh
#!/bin/bash
if [ -f /usr/local/V2bX/V2bX ]; then
    if cat /proc/version 2>/dev/null | grep -Eqi "alpine"; then
        service V2bX status 2>&1 | grep -Eqi "started|running" || [ -f /run/V2bX.pid ] || service V2bX start
    else
        systemctl is-active --quiet V2bX || systemctl start V2bX
    fi
fi
EOF
    chmod +x /usr/local/bin/V2bX_daemon.sh
    (crontab -l 2>/dev/null | grep -v "V2bX_daemon"; echo "* * * * * /bin/bash /usr/local/bin/V2bX_daemon.sh >/dev/null 2>&1") | crontab -
    echo -e "${green}自动化智能自愈守护开启成功！${plain}"
}

stop_daemon() {
    crontab -l 2>/dev/null | grep -v "V2bX_daemon" | crontab -
    rm -f /usr/local/bin/V2bX_daemon.sh
    echo -e "${yellow}自动化智能自愈守护已完全关闭。${plain}"
}
view_vps_info() {
    clear
    echo -e "${cyan}========== 麦卖云小鸡硬件环境全能看板 ==========${plain}"
    echo -n "系统内核: " && uname -r
    echo -n "虚拟化架构: "
    if command -v systemd-detect-virt &>/dev/null; then
        systemd-detect-virt
    else
        if [ -d /proc/vz ]; then echo "OpenVZ"; elif grep -q lxc /proc/1/environ 2>/dev/null; then echo "LXC"; else echo "KVM/Other"; fi
    fi
    echo -n "系统总负载: " && awk '{print $1,$2,$3}' /proc/loadavg
    echo -e "\n${yellow}[磁盘各个分区剩余空余]${plain}"
    df -h | grep -E '^/dev/|/sd|/vd|pve|root' || df -h | head -n 4
    echo -e "\n${yellow}[小鸡网络出网IP与归属地]${plain}"
    ip_info=$(curl -s --connect-timeout 5 https://ipapi.co/json/ 2>/dev/null)
    if [ -n "$ip_info" ]; then
        echo "公网 IP: $(echo "$ip_info" | awk -F'"ip": "' '{print $2}' | awk -F'"' '{print $1}')"
        echo "国家/城市: $(echo "$ip_info" | awk -F'"country_name": "' '{print $2}' | awk -F'"' '{print $1}') - $(echo "$ip_info" | awk -F'"city": "' '{print $2}' | awk -F'"' '{print $1}')"
        echo "运营商(ISP): $(echo "$ip_info" | awk -F'"org": "' '{print $2}' | awk -F'"' '{print $1}')"
    else
        curl -s --connect-timeout 4 ip.sb || echo "无法获取位置数据"
    fi
    echo -e "${cyan}================================================${plain}"
}
process_run() {
    local num
    read -rp "请输入选择 [0-23]: " num
    case "$num" in
        0) edit_config ;;
        1) self_install_core ;; # 完美承接：直接调用自建专属安装逻辑
        2) self_install_core ;; # 完美承接：直接调用自建专属更新逻辑
        3) rm -rf /usr/local/V2bX /etc/V2bX /usr/bin/V2bX /usr/bin/v2bx && echo "已完全卸载" ;;
        4) start_V2bX ;;
        5) stop_V2bX ;;
        6) restart_V2bX ;;
        7) check_status && echo -e "状态: ${green}正在运行${plain}" || echo -e "状态: ${red}未运行${plain}" ;;
        8) view_log ;;
        9) enable_V2bX ;;
        10) disable_V2bX ;;
        11) install_bbr ;;
        12) /usr/local/V2bX/V2bX version 2>/dev/null || echo -e "${green}v114514.14版本${plain}" ;;
        13) /usr/local/V2bX/V2bX x25519 ;;
        14) update_shell ;;
        15) /usr/local/V2bX/V2bX generate ;;
        16) run_clean_script ;;
        17) open_ports ;;
        18) exit 0 ;;
        19) run_network_test ;;
        20) run_deep_log_clean ;;
        21) start_daemon ;;
        22) stop_daemon ;;
        23) view_vps_info ;;
        *) echo -e "${red}请输入正确的数字 [0-23]${plain}" ;;
    esac
}

if [[ $# -gt 0 ]]; then
    case "$1" in
        "start") start_V2bX ;; "stop") stop_V2bX ;; "restart") restart_V2bX ;;
        "status") check_status && echo -e "状态: ${green}正在运行${plain}" || echo -e "状态: ${red}未运行${plain}" ;;
        "enable") enable_V2bX ;; "disable") disable_V2bX ;; "log") view_log ;; "clean") run_clean_script ;;
        "x25519") /usr/local/V2bX/V2bX x25519 ;; "generate") /usr/local/V2bX/V2bX generate ;;
        "daemon_on") start_daemon ;; "daemon_off") stop_daemon ;; "vps") view_vps_info ;;
        "version") /usr/local/V2bX/V2bX version 2>/dev/null || echo -e "${green}v114514.14版本${plain}" ;;
        "update") self_install_core ;;
        "install") self_install_core ;;
        "uninstall") rm -rf /usr/local/V2bX /etc/V2bX /usr/bin/V2bX /usr/bin/v2bx && echo "已完全卸载" ;;
        *) show_menu; process_run ;;
    esac
else
