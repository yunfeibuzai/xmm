open_ports() { 
    echo -e "${yellow}=== 开始系统网络及并发连接数 [永久级] 优化 ===${plain}"
    
    # 1. 通用基础功能：放行全局端口 (Iptables 净化)
    iptables -P INPUT ACCEPT && iptables -P FORWARD ACCEPT && iptables -P OUTPUT ACCEPT && iptables -F 2>/dev/null
    echo -e "${green}[+] 已尝试放行所有 iptables 网络端口${plain}"

    # 2. 全局通用 (含 LXC、Debian、Alpine)：突破最大文件打开数并永久固化 (防止重启复原)
    ulimit -n 65535 2>/dev/null
    
    # 写入 limits.conf 保证普通登录及 PAM 模块永久生效
    if [ -d "/etc/security" ]; then
        sed -i '/^\*.*nofile/d' /etc/security/limits.conf 2>/dev/null
        sed -i '/^root.*nofile/d' /etc/security/limits.conf 2>/dev/null
        cat << 'EOF' >> /etc/security/limits.conf
* soft nofile 65535
* hard nofile 65535
root soft nofile 65535
root hard nofile 65535
EOF
    fi

    # 针对 Systemd 系统的全局默认配置进行永久拉升
    if [ -d "/etc/systemd" ]; then
        if [ -f "/etc/systemd/system.conf" ]; then
            sed -i 's/^#\?DefaultLimitNOFILE=.*/DefaultLimitNOFILE=65535/' /etc/systemd/system.conf 2>/dev/null
        fi
        if [ -f "/etc/systemd/user.conf" ]; then
            sed -i 's/^#\?DefaultLimitNOFILE=.*/DefaultLimitNOFILE=65535/' /etc/systemd/user.conf 2>/dev/null
        fi
        systemctl daemon-reload >/dev/null 2>&1
    fi
    
    # 针对 Shell 环境变量打补丁 (双重保险)
    for file in /etc/profile /root/.profile /root/.bashrc; do
        if [ -f "$file" ]; then
            if ! grep -q "ulimit -n 65535" "$file"; then
                echo "ulimit -n 65535" >> "$file"
            fi
        fi
    done
    echo -e "${green}[+] 已将全局最大连接数(ulimit)永久拉升至 65535 (重启绝不失效)${plain}"

    # 3. 全局通用 (含 LXC)：优化内核高并发网络参数，持久化写入系统层
    local SYSCTL_CONF="/etc/sysctl.conf"
    [ -d "/etc/sysctl.d" ] && SYSCTL_CONF="/etc/sysctl.d/99-network-optimize.conf"

    cat << 'SYS' > "$SYSCTL_CONF"
# 增大并发连接队列
net.core.somaxconn = 65535
net.ipv4.tcp_max_syn_backlog = 65535
# 开启 TCP 端口复用，应对高并发短连接
net.ipv4.tcp_tw_reuse = 1
net.ipv4.ip_local_port_range = 1024 65535
# 增大连接跟踪表（防中转大流量丢包）
net.netfilter.nf_conntrack_max = 1048576
# 优化 TCP 缓冲区
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
SYS
    sysctl -p "$SYSCTL_CONF" >/dev/null 2>&1 || sysctl -p >/dev/null 2>&1
    echo -e "${green}[+] 已永久注入内核级 TCP 高并发与抗丢包优化参数${plain}"

    # 4. 专属逻辑：仅针对 Alpine (及 OpenRC) 的特殊处理
    if [ -f /etc/alpine-release ] || command -v apk &>/dev/null; then
        
        # 4.1 针对 OpenRC 的进程锁永久解除
        if [ -d "/etc/conf.d" ] && [ -f "/etc/rc.conf" ]; then
            if grep -q "rc_ulimit" /etc/rc.conf 2>/dev/null; then
                sed -i 's/^#\?rc_ulimit.*/rc_ulimit="-n 65535"/' /etc/rc.conf
            else
                echo 'rc_ulimit="-n 65535"' >> /etc/rc.conf 2>/dev/null
            fi
        fi
        
        # 4.2 Alpine/LXC 环境强制挂载 Cubic，不搞 BBR
        echo "net.ipv4.tcp_congestion_control = cubic" >> "$SYSCTL_CONF"
        sysctl -p "$SYSCTL_CONF" >/dev/null 2>&1 || sysctl -p >/dev/null 2>&1
        echo -e "${cyan}[+] 当前环境不支持BBR（如LXC容器），已默认配置高并发Cubic算法${plain}"
    else
        # 非 Alpine (例如 Debian) 直接跳过拥塞算法修改，留给你自定义处理
        echo -e "${cyan}[+] 非 Alpine 系统，跳过拥塞算法强制覆盖（保留你自定义的 BBR）。${plain}"
    fi

    echo -e "\n${green}✅ 全局高并发永久级优化彻底完成！(重启设备依然坚挺，无需再次执行。)${plain}"
}

