#!/bin/bash

# 麦卖云 V2bX 后端终极全能王牌脚本 (官方原生核心高可用版)
sh_ver="1.6.0"
filepath=$(readlink -f "$0")

red='\033[0;31m'; green='\033[0;32m'; yellow='\033[0;33m'
magenta='\033[0;35m'; cyan='\033[0;36m'; plain='\033[0m'

[[ $EUID -ne 0 ]] && echo -e "${red}错误：${plain} 必须使用root用户运行此脚本！\n" && exit 1

if cat /etc/issue 2>/dev/null | grep -Eqi "alpine" || cat /proc/version 2>/dev/null | grep -Eqi "alpine"; then
    release="alpine"
else
    release="standard"
fi

# 智能注册全局快捷命令
register_shortcut() {
    if [[ -f "$filepath" ]]; then
        # 绑定 maimai 快捷键
        rm -f /usr/bin/maimai
        ln -sf "$filepath" /usr/bin/maimai
        chmod +x /usr/bin/maimai
        
        # 绑定 v2bx 快捷键
        rm -f /usr/bin/v2bx /usr/bin/V2bX
        ln -sf "$filepath" /usr/bin/v2bx
        ln -sf "$filepath" /usr/bin/V2bX
        chmod +x /usr/bin/v2bx
    fi
}
register_shortcut

show_status() {
    if [[ ! -f /usr/local/V2bX/V2bX ]] || [[ ! -s /usr/local/V2bX/V2bX ]]; then
        echo -e "V2bX 状态: ${red}未安装或核心已损坏(0字节)${plain}"
        return
    fi
    if [[ x"${release}" == x"alpine" ]]; then
        if service V2bX status 2>&1 | grep -Eqi "started|running" || [ -f /run/V2bX.pid ]; then
            echo -e "V2bX 状态: ${green}已运行${plain}"
        else
            echo -e "V2bX 状态: ${red}未运行${plain}"
        fi
    else
        if systemctl is-active --quiet V2bX; then
            echo -e "V2bX 状态: ${green}已运行${plain}"
        else
            echo -e "V2bX 状态: ${red}未运行${plain}"
        fi
    fi
    
    if crontab -l 2>/dev/null | grep -q "V2bX_daemon"; then
        echo -e "自动化守护: ${green}已开启 (每分钟智能自愈)${plain}"
    else
        echo -e "自动化守护: ${red}已关闭${plain}"
    fi
}

