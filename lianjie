#!/usr/bin/env bash

# =========================================================================
#  Repository:  https://github.com/your-username/linux-tcp-optimizer
#  Project:     Linux Mega-Concurrency TCP Optimizer (C10M Edition)
#  Description: 突破 Linux 默认内核限制，全自动自适应解锁千万级并发 (C10M)。
#               完美兼容 LXC/OpenVZ/Docker 容器环境，智能识别只读内核与母鸡限制。
#  License:     MIT
# =========================================================================

# --- [ 1. 基础设置与 UI 组件 ] ---
RED='\033[31m'; GREEN='\033[32m'; YELLOW='\033[33m'; CYAN='\033[36m'; PLAIN='\033[0m'

msg_info() { echo -e "${CYAN}[INFO] $1${PLAIN}"; }
msg_succ() { echo -e "${GREEN}[ OK ] $1${PLAIN}"; }
msg_warn() { echo -e "${YELLOW}[WARN] $1${PLAIN}"; }
msg_err()  { echo -e "${RED}[ERR ] $1${PLAIN}"; }

if [[ $EUID -ne 0 ]]; then
    msg_err "必须使用 root 用户或 sudo 运行此脚本！\n"
    exit 1
fi

clear
echo -e "${YELLOW}=====================================================================${PLAIN}"
echo -e "${CYAN}      🚀 Linux TCP C10M Optimizer - 千万级极端高并发内核注入      ${PLAIN}"
echo -e "${YELLOW}=====================================================================${PLAIN}"

# --- [ 2. 环境与架构智能检测 (LXC 精准判定) ] ---
IS_CONTAINER=false
VIRT_TYPE="unknown"

# 探测容器特征
if [ -f /proc/1/environ ] && grep -qa container= /proc/1/environ; then
    IS_CONTAINER=true; VIRT_TYPE="container"
elif command -v systemd-detect-virt &>/dev/null; then
    VIRT_TYPE=$(systemd-detect-virt 2>/dev/null)
    [[ "$VIRT_TYPE" =~ (lxc|openvz|docker|wsl) ]] && IS_CONTAINER=true
fi

# 兜底检测
if [ "$VIRT_TYPE" = "unknown" ] || [ -z "$VIRT_TYPE" ]; then
    if [ -d /proc/vz ]; then
        IS_CONTAINER=true; VIRT_TYPE="openvz"
    elif grep -iq "kvm" /proc/cpuinfo 2>/dev/null || dmesg 2>/dev/null | grep -iq "kvm"; then
        VIRT_TYPE="kvm"
    fi
fi

msg_info "底层架构扫描完成: [${VIRT_TYPE^^}] | 容器沙盒环境: ${IS_CONTAINER}"

# 仅在非容器环境下尝试加载内核模块 (容器无权加载模块)
if [ "$IS_CONTAINER" = false ]; then
    modprobe nf_conntrack 2>/dev/null
    modprobe tcp_bbr 2>/dev/null
fi

# --- [ 3. 动态探测并发上限 (防 LXC 报错机制) ] ---
TARGET_FILES="10485760"
MAX_SYS_FILES="65535000"
MAX_CONNTRACK="10485760"

if ! ulimit -n ${TARGET_FILES} 2>/dev/null; then
    # 如果设置失败，说明被 LXC 母鸡硬锁限制，获取当前允许的绝对最大值
    ACTUAL_MAX=$(ulimit -Hn 2>/dev/null)
    if [ -n "$ACTUAL_MAX" ] && [ "$ACTUAL_MAX" != "unlimited" ]; then
        TARGET_FILES="$ACTUAL_MAX"
        msg_warn "检测到 LXC/母鸡 进程硬锁！最大文件描述符自动自适应降级至: ${TARGET_FILES}"
    fi
else
    msg_succ "成功突破单进程千万级上限: ${TARGET_FILES}"
fi

# --- [ 4. 解锁系统与服务并发上限 ] ---
msg_info "正在固化 ulimit 与 Systemd 进程限制..."

if [ -d "/etc/security" ]; then
    mkdir -p /etc/security/limits.d
    cat << EOF > /etc/security/limits.d/99-megaconcurrency.conf
* soft nofile ${TARGET_FILES}
* hard nofile ${TARGET_FILES}
root soft nofile ${TARGET_FILES}
root hard nofile ${TARGET_FILES}
EOF
fi

if [ -d "/etc/systemd" ] && command -v systemctl &>/dev/null; then
    mkdir -p /etc/systemd/system.conf.d /etc/systemd/user.conf.d
    echo -e "[Manager]\nDefaultLimitNOFILE=${TARGET_FILES}:${TARGET_FILES}" > /etc/systemd/system.conf.d/99-limits.conf
    echo -e "[Manager]\nDefaultLimitNOFILE=${TARGET_FILES}:${TARGET_FILES}" > /etc/systemd/user.conf.d/99-limits.conf
    systemctl daemon-reload >/dev/null 2>&1
fi

if [ -d "/etc/profile.d" ]; then
    echo "ulimit -n ${TARGET_FILES} 2>/dev/null" > /etc/profile.d/99-megaconcurrency.sh
else
    grep -q "ulimit -n" /etc/profile || echo "ulimit -n ${TARGET_FILES} 2>/dev/null" >> /etc/profile
fi

# --- [ 5. 激进内核网络调优 (LXC 读写分离过滤) ] ---
msg_info "正在注入内核网络参数 (自适应过滤只读选项)..."
SYSCTL_CONF="/etc/sysctl.d/99-c10m-network.conf"
mkdir -p /etc/sysctl.d 2>/dev/null
> "$SYSCTL_CONF" # 清空/创建配置文件

# 定义参数注入函数，带有容错检测
inject_sysctl() {
    local key="$1"
    local value="$2"
    # 尝试在当前环境试运行写入 (过滤只读报错)
    if sysctl -w "${key}=${value}" >/dev/null 2>&1; then
        echo "${key} = ${value}" >> "$SYSCTL_CONF"
    fi
}

# --- 注入系统级参数 (容器下大概率被过滤，静默处理) ---
inject_sysctl "fs.file-max" "${MAX_SYS_FILES}"
inject_sysctl "fs.nr_open" "${TARGET_FILES}"

# --- 注入网络并发与缓冲区参数 ---
inject_sysctl "net.ipv4.ip_local_port_range" "1024 65535"
inject_sysctl "net.core.somaxconn" "1048576"
inject_sysctl "net.ipv4.tcp_max_syn_backlog" "1048576"
inject_sysctl "net.ipv4.tcp_max_tw_buckets" "2097152"
inject_sysctl "net.core.netdev_max_backlog" "1048576"

inject_sysctl "net.ipv4.tcp_tw_reuse" "1"
inject_sysctl "net.ipv4.tcp_fin_timeout" "15"
inject_sysctl "net.ipv4.tcp_syncookies" "1"

inject_sysctl "net.netfilter.nf_conntrack_max" "${MAX_CONNTRACK}"
inject_sysctl "net.nf_conntrack_max" "${MAX_CONNTRACK}"

inject_sysctl "net.core.rmem_max" "67108864"
inject_sysctl "net.core.wmem_max" "67108864"
inject_sysctl "net.ipv4.tcp_rmem" "4096 87380 67108864"
inject_sysctl "net.ipv4.tcp_wmem" "4096 65536 67108864"
inject_sysctl "net.ipv4.tcp_window_scaling" "1"
inject_sysctl "net.ipv4.tcp_fastopen" "3"

# --- [ 6. 智能 BBR 拥塞控制自适应 (LXC 透传检测) ] ---
msg_info "正在探测最优 TCP 拥塞控制算法..."

# 探测当前内核支持的算法
AVAILABLE_CC=$(sysctl -n net.ipv4.tcp_available_congestion_control 2>/dev/null)
CURRENT_CC=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)

if echo "$AVAILABLE_CC" | grep -qi "bbr"; then
    msg_succ "检测到内核支持 BBR (母鸡已开启透传)，正在激活..."
    inject_sysctl "net.core.default_qdisc" "fq"
    inject_sysctl "net.ipv4.tcp_congestion_control" "bbr"
else
    # 针对已魔改 BBR (如 bbr_plus) 的检测
    if echo "$CURRENT_CC" | grep -qi "bbr"; then
         msg_succ "检测到运行中的自定义 BBR 变体: [${CURRENT_CC}]"
         inject_sysctl "net.ipv4.tcp_congestion_control" "${CURRENT_CC}"
    else
         msg_warn "当前环境不支持 BBR，已自适应锁定为 Cubic 稳定算法。"
         inject_sysctl "net.ipv4.tcp_congestion_control" "cubic"
    fi
fi

# 最终持久化应用
sysctl -p "$SYSCTL_CONF" >/dev/null 2>&1
msg_succ "自适应网络调优参数已注入完成。"

# --- [ 7. 结束提示 ] ---
echo -e "\n${GREEN}=====================================================================${PLAIN}"
echo -e "${GREEN}   ✅ 【C10M 千万级并发】极致网络底层优化已彻底完成！      ${PLAIN}"
echo -e "${GREEN}=====================================================================${PLAIN}"
echo -e "${YELLOW} 💡 环境验证指南：${PLAIN}"
echo -e "${CYAN} 1. 请务必【断开当前 SSH 并重新连接】以刷新缓存。${PLAIN}"
echo -e "${CYAN} 2. 重新连接后，输入命令 ${YELLOW}ulimit -n${CYAN} 进行验证。${PLAIN}"
echo -e "${CYAN} 3. 当前系统已根据 [${VIRT_TYPE^^}] 架构自动过滤了无权写入的只读参数。${PLAIN}\n"
