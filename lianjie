#!/bin/bash

# =========================================================================
#  Project:   Linux Mega-Concurrency TCP Optimizer (Enterprise Edition)
#  Function:  全自动自适应解锁百万级并发，深度调优内核网络、缓冲区与 智能架构BBR识别
#  Platform:  CentOS / RHEL / Debian / Ubuntu / Alpine / Rocky / Alma
#  Arch:      Systemd & OpenRC / 智能识别 KVM 自定义BBR与非KVM环境自适应
# =========================================================================

# 字体颜色定义
red='\033[31m'; green='\033[32m'; yellow='\033[33m'; cyan='\033[36m'; plain='\033[0m'

# 检查 root 权限
[[ $EUID -ne 0 ]] && echo -e "${red}Error:${plain} 必须使用 root 用户或 sudo 运行此脚本！\n" && exit 1

echo -e "${yellow}====================================================${plain}"
echo -e "${cyan}    开始注入 [百万级上限 + BBR自适应] 极端高并发内核优化   ${plain}"
echo -e "${yellow}====================================================${plain}"

# -------------------------------------------------------------------------
# 0. 环境与虚拟化架构识别 (智能精准判定)
# -------------------------------------------------------------------------
IS_CONTAINER=false
VIRT_TYPE="unknown"

if [ -f /proc/1/environ ] && grep -qa container= /proc/1/environ; then
    IS_CONTAINER=true
    VIRT_TYPE="container"
elif command -v systemd-detect-virt &>/dev/null; then
    VIRT_TYPE=$(systemd-detect-virt 2>/dev/null)
    if [ "$VIRT_TYPE" = "lxc" ] || [ "$VIRT_TYPE" = "openvz" ] || [ "$VIRT_TYPE" = "docker" ]; then
        IS_CONTAINER=true
    fi
fi

# 如果 systemd-detect-virt 没查出来，尝试通过 dmesg 或 openvz 特征二次核对
if [ "$VIRT_TYPE" = "unknown" ]; then
    if [ -d /proc/vz ]; then
        IS_CONTAINER=true
        VIRT_TYPE="openvz"
    elif grep -iq "kvm" /proc/cpuinfo 2>/dev/null || dmesg 2>/dev/null | grep -iq "kvm"; then
        VIRT_TYPE="kvm"
    fi
fi

# 预先尝试加载连接跟踪模块
modprobe nf_conntrack 2>/dev/null

# -------------------------------------------------------------------------
# 1. 放行全局端口 (网络净化)
# -------------------------------------------------------------------------
echo -e "${yellow}[1/6] 正在配置防火墙，放行所有网络端口...${plain}"
if command -v iptables &>/dev/null; then
    iptables -P INPUT ACCEPT && iptables -P FORWARD ACCEPT && iptables -P OUTPUT ACCEPT && iptables -F 2>/dev/null
    echo -e "${green}[+] Iptables 规则已清空并设置为全局放行${plain}"
else
    echo -e "${cyan}[i] 未检测到 iptables，略过此步${plain}"
fi

# -------------------------------------------------------------------------
# 2. 解锁系统最大文件打开数 (ulimit) 到 1,048,576
# -------------------------------------------------------------------------
echo -e "${yellow}[2/6] 正在提升系统最大文件打开数 (ulimit) 至百万级...${plain}"
ulimit -n 1048576 2>/dev/null

if [ -d "/etc/security" ]; then
    sed -i '/nofile/d' /etc/security/limits.conf 2>/dev/null
    cat << 'LIMITS' >> /etc/security/limits.conf
* soft nofile 1048576
* hard nofile 1048576
root soft nofile 1048576
root hard nofile 1048576
LIMITS
    echo -e "${green}[+] /etc/security/limits.conf 静态配置已固化${plain}"
fi

# -------------------------------------------------------------------------
# 3. 规范化解锁 Systemd 全局默认进程限制 (使用 drop-in 目录)
# -------------------------------------------------------------------------
if [ -d "/etc/systemd" ]; then
    echo -e "${yellow}[3/6] 检测到 Systemd 环境，正在规范化注入服务限制...${plain}"
    mkdir -p /etc/systemd/system.conf.d /etc/systemd/user.conf.d 2>/dev/null
    
    echo -e "[Manager]\nDefaultLimitNOFILE=1048576" > /etc/systemd/system.conf.d/99-limits.conf
    echo -e "[Manager]\nDefaultLimitNOFILE=1048576" > /etc/systemd/user.conf.d/99-limits.conf
    
    systemctl daemon-reload >/dev/null 2>&1
    echo -e "${green}[+] Systemd 配置目录已注入独立限制文件并重载${plain}"
fi

# -------------------------------------------------------------------------
# 4. 固化到 Shell 环境变量
# -------------------------------------------------------------------------
echo -e "${yellow}[4/6] 正在将限制写入 Shell 环境变量...${plain}"
for file in /etc/profile /root/.profile /root/.bashrc; do
    if [ -f "$file" ]; then
        sed -i '/ulimit -n/d' "$file" 2>/dev/null
        echo "ulimit -n 1048576" >> "$file"
    fi
done

if [ -f /etc/alpine-release ] || command -v apk &>/dev/null; then
    if [ -d "/etc/conf.d" ] && [ -f "/etc/rc.conf" ]; then
        sed -i '/rc_ulimit/d' /etc/rc.conf 2>/dev/null
        echo 'rc_ulimit="-n 1048576"' >> /etc/rc.conf 2>/dev/null
    fi
    echo -e "${cyan}[+] Alpine/LXC 环境已额外解除 OpenRC 进程锁${plain}"
fi

# -------------------------------------------------------------------------
# 5. 激进式内核网络参数调优 (扩充并发队列与缓冲区)
# -------------------------------------------------------------------------
echo -e "${yellow}[5/6] 正在向内核注入高级 TCP 吞吐与抗并发参数...${plain}"
SYSCTL_CONF="/etc/sysctl.conf"
[ -d "/etc/sysctl.d" ] && SYSCTL_CONF="/etc/sysctl.d/99-super-network.conf"

rm -f /etc/sysctl.d/99-super-network.conf 2>/dev/null

cat << 'SYS' > "$SYSCTL_CONF"
# 开源核心调优：必须先解锁内核级别的总线最大文件描述符上限
fs.file-max = 2097152
fs.nr_open = 1048576

# 极大化本地可用端口范围，防止高并发下端口耗尽
net.ipv4.ip_local_port_range = 1024 65535

# 极大化高并发连接队列与半连接队列大小 (防止请求被直接拒绝)
net.core.somaxconn = 262144
net.ipv4.tcp_max_syn_backlog = 262144
net.ipv4.tcp_max_tw_buckets = 524288

# 开启快速回收与 TCP 端口复用
net.ipv4.tcp_tw_reuse = 1
net.ipv4.tcp_fin_timeout = 15

# 极大化网络连接跟踪表上限
net.netfilter.nf_conntrack_max = 2097152
net.nf_conntrack_max = 2097152

# 极端高带宽/高并发内核缓冲区调优 (最大支持到 32MB 动态缓冲区)
net.core.rmem_max = 33554432
net.core.wmem_max = 33554432
net.ipv4.tcp_rmem = 4096 87380 33554432
net.ipv4.tcp_wmem = 4096 65536 33554432

# 启用 TCP 窗口缩放
net.ipv4.tcp_window_scaling = 1

# 开启 TCP Fast Open
net.ipv4.tcp_fastopen = 3
SYS

# -------------------------------------------------------------------------
# 6. 核心优化：智能拥塞控制算法自适应策略 (根据你的要求量身定制)
# -------------------------------------------------------------------------
echo -e "${yellow}[6/6] 正在智能匹配最强 TCP 拥塞控制算法...${plain}"

# 提取当前系统正在生效的算法，判定用户是否魔改过
CURRENT_CC=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)

if [ "$VIRT_TYPE" = "kvm" ] || [ "$VIRT_TYPE" = "bhyve" ]; then
    echo -e "${green}[+] 识别到当前为标准核心 KVM 架构${plain}"
    
    # 检查用户当前是否已经在使用某种 BBR (包含原版、plus、魔改等)
    if echo "$CURRENT_CC" | grep -qi "bbr"; then
        echo -e "${green}[+] 检测到用户已预设自定义 BBR 变体算法 [${CURRENT_CC}]，脚本将自动保留不作覆盖调换！${plain}"
        echo "net.ipv4.tcp_congestion_control = ${CURRENT_CC}" >> "$SYSCTL_CONF"
        # 挂载高性能公平队列
        if sysctl net.core.default_qdisc 2>/dev/null | grep -q "fq"; then
            echo "net.core.default_qdisc = fq" >> "$SYSCTL_CONF"
        fi
    else
        # 如果是 KVM 但用户没装 BBR，我们帮他开启官方原生标准 BBR
        if sysctl net.ipv4.tcp_available_congestion_control 2>/dev/null | grep -q "bbr"; then
            cat << 'BBR' >> "$SYSCTL_CONF"
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr
BBR
            echo -e "${green}[+] 检测到内核支持，已帮此 KVM 节点激活官方原生 BBR 加速 + FQ 队列${plain}"
        else
            echo "net.ipv4.tcp_congestion_control = cubic" >> "$SYSCTL_CONF"
            echo -e "${cyan}[i] 该 KVM 内核较老且不支持 BBR，自动降级为 Cubic 算法${plain}"
        fi
    fi
else
    # 非 KVM 架构 (如 LXC、OpenVZ、Container 或者已识别为非KVM的未知架构)
    echo -e "${yellow}[i] 当前虚拟化架构为: [${VIRT_TYPE}] (非KVM或受限容器环境)${plain}"
    echo -e "${cyan}[+] 遵照防爆安全规则，强制降级并默认锁定最稳定的 Cubic 高并发抗丢包算法${plain}"
    echo "net.ipv4.tcp_congestion_control = cubic" >> "$SYSCTL_CONF"
fi

# 统一动态生效
if [ -d "/etc/sysctl.d" ]; then
    sysctl --system >/dev/null 2>&1 || sysctl -p "$SYSCONF" >/dev/null 2>&1
else
    sysctl -p >/dev/null 2>&1
fi

echo -e "${green}[+] 内核网络参数已成功应用到当前系统${plain}"

# -------------------------------------------------------------------------
# 结束提示 (修复了原先多余的 \033 和 -v 传帮漏洞)
# -------------------------------------------------------------------------
echo -e "\n${green}====================================================${plain}"
echo -e "${green}   ✅ 【百万级高并发】超级永久网络优化彻底完成！      ${plain}"
echo -e "${green}====================================================${plain}"
echo -e "${yellow}💡 提示：由于当前会话的文件描述符限制已在后台修改，${plain}"
echo -e "${yellow}   请断开当前的 SSH 终端并重新连接，即可完全刷新生效。${plain}"
echo -e "${yellow}   重新连接后可输入 'ulimit -n' 验证，数值应为 1048576。${plain}\n"
